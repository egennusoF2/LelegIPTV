---
import DocsLayout from "../layouts/DocsLayout.astro"
import HubCard from "../components/HubCard.astro"
import type { IconName } from "../components/Icon.astro"

const base = import.meta.env.BASE_URL.replace(/\/$/, "")

const cards: { href: string; title: string; body: string; icon: IconName; featured?: boolean }[] = [
  {
    href: `${base}/getting-started/`,
    title: "Getting started",
    body: "Install LelegIPTV, sign in, and start your first stream.",
    icon: "rocket",
    featured: true,
  },
  {
    href: `${base}/playlists/`,
    title: "Playlists (Xtream + M3U)",
    body: "Add Xtream Codes credentials or paste an M3U / M3U8 URL.",
    icon: "playlist",
  },
  {
    href: `${base}/external-players/`,
    title: "External players",
    body: "Hand off playback to MPV, VLC, or any installed Android video app.",
    icon: "external",
  },
  {
    href: `${base}/keyboard-and-d-pad/`,
    title: "Keyboard + D-pad",
    body: "Shortcuts for desktop and spatial navigation for TV remotes.",
    icon: "keyboard",
  },
  {
    href: `${base}/troubleshooting/`,
    title: "Troubleshooting",
    body: "Test a stream, fix EPG offsets, recover from a failed login.",
    icon: "lifebuoy",
  },
]
---

<DocsLayout
  title="LelegIPTV docs"
  description="Documentation for LelegIPTV, a cross-platform IPTV player for Xtream Codes and M3U playlists."
  lede="A cross-platform IPTV player for Xtream Codes and M3U / M3U8 playlists. Local artifacts for Windows, macOS, Linux, Android, iOS, Tizen TV, and the web."
>
  <p>
    LelegIPTV builds local artifacts from this repository instead of pointing
    users to official store listings. The same app runs on a phone in portrait,
    a tablet, a desktop with keyboard + mouse, and a TV with a D-pad remote.
  </p>

  <div class="my-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
    {cards.map((card) => <HubCard {...card} />)}
  </div>

  <h2 id="quick-links">Quick links</h2>
  <ul>
    <li><a href={`${base}/getting-started/`}>Build artifact paths</a></li>
    <li><a href="https://github.com/egennusoF2/LelegIPTV/releases/latest" rel="noopener" target="_blank">GitHub release artifacts</a></li>
    <li><a href="https://github.com/egennusoF2/LelegIPTV/discussions" rel="noopener" target="_blank">Discussions</a></li>
    <li><a href="https://github.com/egennusoF2/LelegIPTV/issues" rel="noopener" target="_blank">Report an issue</a></li>
  </ul>
</DocsLayout>
