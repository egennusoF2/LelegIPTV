---
interface Props {
  type?: "note" | "tip" | "warning"
  title?: string
}

const { type = "note", title } = Astro.props

const config = {
  note: {
    label: "Note",
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/>',
    aside: "bg-surface border-l-accent",
    ink: "text-fg-3",
  },
  tip: {
    label: "Tip",
    icon: '<path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1V18h6v-1.2c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2Z"/>',
    aside: "bg-ok-soft border-l-ok",
    ink: "text-ok",
  },
  warning: {
    label: "Warning",
    icon: '<path d="M12 3 2 21h20L12 3Z"/><path d="M12 10v5M12 18h.01"/>',
    aside: "bg-warn-soft border-l-warn",
    ink: "text-warn",
  },
} as const

const meta = config[type]
const displayTitle = title ?? meta.label
---

<aside
  class:list={[
    "callout my-5 flex gap-3 rounded-[10px] border border-line-soft border-l-[3px] px-4 py-3.5 text-[0.92rem] leading-relaxed",
    meta.aside,
  ]}
>
  <svg
    class:list={["mt-[0.15rem] h-[18px] w-[18px] shrink-0", meta.ink]}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    set:html={meta.icon}
  />
  <div class="min-w-0 flex-1">
    <p class:list={["m-0 mb-1 text-[0.75rem] font-semibold uppercase tracking-[0.06em]", meta.ink]}>
      {displayTitle}
    </p>
    <div class="callout-body">
      <slot />
    </div>
  </div>
</aside>

<style>
  .callout :global(p) {
    margin: 0 0 0.5rem;
  }
  .callout :global(p:last-child) {
    margin-bottom: 0;
  }
  .callout :global(code) {
    font-size: 0.85em;
  }
  .callout-body :global(*) {
    color: var(--color-fg);
  }
</style>
