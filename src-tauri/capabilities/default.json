{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-progress-bar",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**/*" },
        { "url": "https://**/*" },
        { "url": "*://127.0.0.1:*" },
        { "url": "*://127.0.0.1:*/*" },
        { "url": "*://localhost:*" },
        { "url": "*://localhost:*/*" },
        { "url": "http://127.0.0.1:*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*" },
        { "url": "http://localhost:*/*" },
        { "url": "*://*:*" },
        { "url": "*://*:*/*" }
      ]
    },
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-create",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOWNLOAD/**" },
        { "path": "$VIDEO/**" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:default",
    "clipboard-manager:allow-write-text",
    "notification:default",
    "log:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://**/*" },
        { "url": "http://**/*" }
      ]
    }
  ]
}
