{
  "productName": "LelegIPTV",
  "mainBinaryName": "leleg-iptv",
  "version": "1.6.0",
  "identifier": "com.lelegiptv.player",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4321",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LelegIPTV",
        "width": 1300,
        "height": 850,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "focus": true,
        "visible": false,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOWNLOAD/**",
          "$VIDEO/**",
          "$HOME/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "iOS": {
      "developmentTeam": "F925SY4K37",
      "minimumSystemVersion": "14.0",
      "infoPlist": "Info.ios.plist"
    },
    "publisher": "LelegIPTV",
    "category": "public.app-category.video",
    "copyright": "© 2026 LelegIPTV",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },

  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE2NERBRENFQzczNDZENjQKUldSa2JUVEh6cTFOcHJzVi9PYTB0TWZFYUZEV3RrdW5LRk56cmhDcjdxQlJ1QldjbXAwNEVxWHQK",
      "endpoints": [
        "https://github.com/egennusoF2/LelegIPTV/releases/latest/download/latest.json"
      ]
    }
  }
}
