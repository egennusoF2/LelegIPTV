{
  "name": "leleg-iptv",
  "type": "module",
  "version": "1.6.0",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "astro dev --host",
    "dev:stop": "bash ./scripts/kill-dev-server.sh",
    "dev:clean": "bash ./scripts/kill-dev-server.sh && rm -rf node_modules/.vite .astro && astro dev --host --force",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "tauri": "tauri",
    "tauri:android": "tauri android",
    "tauri:android:build": "tauri android build",
    "tauri:ios": "tauri ios",
    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:dev:device": "tauri ios dev \"iPhone di Emanuele\" --host",
    "tauri:ios:build": "tauri ios build",
    "tizen:prepare": "node ./scripts/prepare-tizen.mjs",
    "tizen:build": "TIZEN=1 astro build",
    "build:all": "node ./scripts/build-all.mjs",
    "build:all:web": "node ./scripts/build-all.mjs --only=web,tizen --skip-test --skip-lint",
    "build:web": "astro build",
    "build:pages": "PUBLIC_WEB_STREAM_PROXY=true astro build",
    "build:tauri": "astro build",
    "clean:dmg": "bash ./scripts/clean-stale-dmg.sh",
    "build:desktop": "bash ./scripts/clean-stale-dmg.sh && tauri build",
    "build:mac": "pnpm run build:desktop",
    "build:android": "tauri android build",
    "build:ios": "tauri ios build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sync:upstream": "bash ./scripts/sync-upstream.sh",
    "screenshots": "node ./src/scripts/capture-screenshots.mjs",
    "msix": "node ./buildfiles/make-msix-template.mjs",
    "sync-version": "node ./buildfiles/sync-version.mjs",
    "icons:sync": "bash ./scripts/sync-brand-icons.sh",
    "deploy:web": "pnpm build:pages && wrangler pages deploy --project-name=leleg-iptv",
    "deploy:pages": "wrangler pages deploy --project-name=leleg-iptv",
    "tizen:serve": "node ./scripts/tizen-dev-server.mjs"
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.9",
    "@astrojs/svelte": "^8.1.1",
    "@fontsource-variable/geist": "5.2.8",
    "@fontsource/instrument-serif": "5.2.8",
    "@tabler/icons-svelte": "^3.44.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "artplayer": "^5.4.0",
    "astro": "^6.3.3",
    "dashjs": "^5.2.0",
    "dompurify": "^3.4.3",
    "hls.js": "^1.6.16",
    "marked": "^18.0.3",
    "mpegts.js": "^1.8.0",
    "shaka-player": "^5.1.7",
    "svelte": "^5.55.7",
    "tailwindcss": "^4.3.0",
    "tauri-plugin-android-fs-api": "28.1.0",
    "typescript": "^6.0.3",
    "video.js": "^8.23.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.1",
    "@vite-pwa/astro": "^1.2.0",
    "@vitest/expect": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "magic-string": "^0.30.21",
    "playwright": "^1.60.0",
    "svelte-eslint-parser": "^1.6.1",
    "tiny-glob": "^0.2.9",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.97.0"
  }
}
