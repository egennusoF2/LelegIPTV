---
import Sidebar from "@/components/Sidebar.astro"
import TitleBar from "@/components/TitleBar.astro"
import WindowResizeEdges from "@/components/WindowResizeEdges.astro"
import CatalogWarmingIndicator from "@/components/CatalogWarmingIndicator.svelte"
import "../styles/global.css"

interface Props {
  pageTitle?: string
}
const { pageTitle } = Astro.props
const documentTitle = pageTitle
  ? `${pageTitle} | Extreme InfiniTV`
  : "Extreme InfiniTV"
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1,viewport-fit=cover"
    />
    <title>{documentTitle}</title>
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e1628" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      try {
        if (sessionStorage.getItem("xt_splash_done") === "1") {
          document.documentElement.setAttribute("data-splash-done", "");
        }
      } catch (e) {}
      try {
        var fontScale = parseFloat(localStorage.getItem("xt_font_scale") || "1");
        if (!isFinite(fontScale) || fontScale < 0.75 || fontScale > 2) fontScale = 1;
        document.documentElement.style.setProperty("--xt-font-scale", String(fontScale));
        try {
          var uaPlatform = (navigator.userAgent || "").toLowerCase();
          if (uaPlatform.indexOf("android") !== -1) {
            document.documentElement.setAttribute("data-platform", "android");
          }
          var hasTauri = !!window.__TAURI_INTERNALS__ || !!window.__TAURI__;
          if (hasTauri && uaPlatform.indexOf("android") === -1) {
            document.documentElement.setAttribute("data-tauri-desktop", "1");
          }
        } catch (e) {}
        var cw = parseFloat(localStorage.getItem("xt_channels_w") || "");
        if (isFinite(cw) && cw >= 18 && cw <= 60) {
          document.documentElement.style.setProperty("--xt-channels-w", cw + "rem");
        }
        // Auto-enable perf mode on TV / Leanback devices
        var perfStored = localStorage.getItem("xt_perf_mode");
        if (perfStored === null) {
          var isTvDevice = false;
          try {
            if (window.AndroidDeviceInfo && typeof window.AndroidDeviceInfo.isTv === "function") {
              isTvDevice = !!window.AndroidDeviceInfo.isTv();
            }
          } catch (e) {}
          if (!isTvDevice) {
            try {
              var ua = (navigator.userAgent || "").toLowerCase();
              if (
                ua.indexOf(" tv ") !== -1 ||
                ua.indexOf("smart-tv") !== -1 ||
                ua.indexOf("smarttv") !== -1 ||
                ua.indexOf("googletv") !== -1 ||
                ua.indexOf("appletv") !== -1 ||
                ua.indexOf("hbbtv") !== -1 ||
                ua.indexOf("netcast") !== -1 ||
                ua.indexOf("nettv") !== -1 ||
                ua.indexOf("aft") !== -1 ||
                ua.indexOf("crkey") !== -1 ||
                ua.indexOf("philipstv") !== -1 ||
                ua.indexOf("bravia") !== -1
              ) {
                isTvDevice = true;
              }
            } catch (e) {}
          }
          if (isTvDevice) {
            localStorage.setItem("xt_perf_mode", "1");
            localStorage.setItem("xt_perf_mode_auto", "1");
            perfStored = "1";
          }
        }
        if (perfStored === "1") {
          document.documentElement.setAttribute("data-perf-mode", "on");
        }

        // TV safe-area inset
        var overscanStored = localStorage.getItem("xt_tv_overscan");
        var overscan = parseFloat(overscanStored || "");
        if (!isFinite(overscan) || overscan < 0 || overscan > 8) {
          if (overscanStored === null) {
            var overscanIsTv = false;
            try {
              if (window.AndroidDeviceInfo && typeof window.AndroidDeviceInfo.isTv === "function") {
                overscanIsTv = !!window.AndroidDeviceInfo.isTv();
              }
            } catch (e) {}
            if (overscanIsTv) {
              overscan = 4;
              localStorage.setItem("xt_tv_overscan", "4");
              localStorage.setItem("xt_tv_overscan_auto", "1");
            } else {
              overscan = 0;
            }
          } else {
            overscan = 0;
          }
        }
        if (overscan > 0) {
          document.documentElement.style.setProperty("--xt-tv-overscan", String(overscan));
          document.documentElement.setAttribute("data-tv-overscan", "");
        }

        var KNOWN_LOCALES = ["en","es","de","fr","pt-BR","it","ru","zh","ja","tr","ar","ur","nl","hi","id","pl"];
        var RTL_LOCALES = ["ar","ur"];
        var storedLocale = localStorage.getItem("xt_locale") || "";
        if (storedLocale && KNOWN_LOCALES.indexOf(storedLocale) !== -1) {
          document.documentElement.setAttribute("lang", storedLocale);
          document.documentElement.setAttribute(
            "dir",
            RTL_LOCALES.indexOf(storedLocale) !== -1 ? "rtl" : "ltr"
          );
        }

        // Translate [data-i18n*] elements before first paint
        if (storedLocale && storedLocale !== "en") {
          var rawMessages = localStorage.getItem("xt_locale_messages_v3");
          try { localStorage.removeItem("xt_locale_messages_v1"); } catch (e) {}
          try { localStorage.removeItem("xt_locale_messages_v2"); } catch (e) {}
          if (rawMessages) {
            var cached = JSON.parse(rawMessages);
            if (cached && cached.code === storedLocale && cached.messages) {
              var msgs = cached.messages;
              var translateEl = function (el) {
                if (!el || el.nodeType !== 1) return;
                var textKey = el.getAttribute("data-i18n");
                if (textKey && msgs[textKey] != null) el.textContent = msgs[textKey];
                var htmlKey = el.getAttribute("data-i18n-html");
                if (htmlKey && msgs[htmlKey] != null) el.innerHTML = msgs[htmlKey];
                var attrSpec = el.getAttribute("data-i18n-attr");
                if (attrSpec) {
                  var pairs = attrSpec.split(";");
                  for (var pi = 0; pi < pairs.length; pi++) {
                    var parts = pairs[pi].split(":");
                    var attrName = (parts[0] || "").trim();
                    var attrKey = (parts[1] || "").trim();
                    if (attrName && attrKey && msgs[attrKey] != null) {
                      el.setAttribute(attrName, msgs[attrKey]);
                    }
                  }
                }
              };
              var i18nObserver = new MutationObserver(function (mutations) {
                for (var mi = 0; mi < mutations.length; mi++) {
                  var added = mutations[mi].addedNodes;
                  for (var ai = 0; ai < added.length; ai++) {
                    var node = added[ai];
                    if (node.nodeType !== 1) continue;
                    if (
                      node.hasAttribute("data-i18n") ||
                      node.hasAttribute("data-i18n-html") ||
                      node.hasAttribute("data-i18n-attr")
                    ) {
                      translateEl(node);
                    }
                    var matches = node.querySelectorAll
                      ? node.querySelectorAll("[data-i18n], [data-i18n-html], [data-i18n-attr]")
                      : null;
                    if (matches) {
                      for (var qi = 0; qi < matches.length; qi++) translateEl(matches[qi]);
                    }
                  }
                }
              });
              i18nObserver.observe(document.documentElement, { childList: true, subtree: true });
              document.addEventListener("DOMContentLoaded", function () {
                i18nObserver.disconnect();
              });
            }
          }
        }

        var currentTheme = localStorage.getItem("xt_theme") || "dark";
        if (currentTheme === "light") document.documentElement.style.colorScheme = "light";
        else if (currentTheme === "dark") document.documentElement.style.colorScheme = "dark";

        function applyAndroidStatusBar(theme) {
          try {
            if (!window.AndroidStatusBar) return;
            var isLight;
            if (theme === "light") isLight = true;
            else if (theme === "dark") isLight = false;
            else isLight = !window.matchMedia("(prefers-color-scheme: dark)").matches;
            window.AndroidStatusBar.setAppearance(isLight);
          } catch (e) {}
        }
        applyAndroidStatusBar(currentTheme);
        var systemThemeMql = window.matchMedia("(prefers-color-scheme: dark)");
        if (systemThemeMql.addEventListener) {
          systemThemeMql.addEventListener("change", function () {
            var t = localStorage.getItem("xt_theme") || "dark";
            if (t !== "light" && t !== "dark") applyAndroidStatusBar(t);
          });
        }
        window.__applyAndroidStatusBar = applyAndroidStatusBar;
      } catch (e) {}
    </script>
  </head>

  <body
    class="antialiased bg-bg text-fg selection:bg-accent-soft
           h-dvh min-h-0 overflow-hidden
           flex flex-col
           pt-[env(safe-area-inset-top)]
           pr-[env(safe-area-inset-right)]"
  >
    <div id="xt-app-splash" aria-hidden="true">
      <canvas id="xt-app-splash-bg" aria-hidden="true"></canvas>
      <div class="xt-app-splash__inner">
        <div class="xt-app-splash__mark-wrap">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="xt-app-splash__svg"
            aria-hidden="true"
          >
            <path
              id="xt-app-splash-path"
              class="xt-app-splash__base"
              d="M18.1777 8C23.2737 8 23.2737 16 18.1777 16C13.0827 16 11.0447 8 5.43875 8C0.85375 8 0.85375 16 5.43875 16C11.0447 16 13.0828 8 18.1788 8H18.1777Z"
            />
          </svg>
          <canvas class="xt-app-splash__comet" aria-hidden="true"></canvas>
        </div>
        <span class="xt-app-splash__wordmark">
          <span class="xt-app-splash__wordmark-1">Extreme&nbsp;Infini</span><span class="xt-app-splash__wordmark-2">TV</span>
        </span>
      </div>
    </div>
    <TitleBar />
    <WindowResizeEdges />
    <div
      class="flex-1 min-h-0 flex flex-col md:flex-row landscape-phone:flex-row"
    >
      <Sidebar />
      <div
        class="flex-1 min-w-0 min-h-0 flex flex-col order-first md:order-0
                overflow-x-clip overflow-y-auto"
      >
        <slot />
      </div>
    </div>
    <CatalogWarmingIndicator client:idle />
  </body>
</html>

<style is:global>
  html[data-tauri-desktop] {
    --xt-titlebar-h: 2.25rem;
  }
  html[data-tauri-desktop] body {
    padding-top: var(--xt-titlebar-h);
  }

  /* TV overscan: shrink the layout in from each viewport edge so
     content stays inside the TV's safe area. Sidebar uses `sticky`
     (not fixed), so body padding cascades through the whole flex
     layout. Toast offsets +overscan-y in toast.ts so notifications
     stay visible too. */
  html[data-tv-overscan] body {
    padding-top: max(
      env(safe-area-inset-top),
      calc(var(--xt-tv-overscan, 0) * 1vh)
    );
    padding-right: max(
      env(safe-area-inset-right),
      calc(var(--xt-tv-overscan, 0) * 1vw)
    );
    padding-bottom: calc(var(--xt-tv-overscan, 0) * 1vh);
    padding-left: calc(var(--xt-tv-overscan, 0) * 1vw);
  }
  html[data-tauri-desktop][data-tv-overscan] body {
    padding-top: max(
      env(safe-area-inset-top),
      calc(var(--xt-titlebar-h) + var(--xt-tv-overscan, 0) * 1vh)
    );
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
    }
  }

  :is(a, button, input, summary, [tabindex]):focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 0;
  }

  #xt-app-splash {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(
        ellipse 92vmin 64vmin at 50% 48%,
        color-mix(in oklch, var(--color-accent) 5%, var(--color-bg)),
        var(--color-bg) 78%
      ),
      var(--color-bg);
    opacity: 1;
    transition: opacity 360ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  :root[data-splash-done] #xt-app-splash {
    display: none;
  }
  #xt-app-splash[data-hiding="true"] {
    opacity: 0;
  }

  #xt-app-splash-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
    opacity: 0;
    animation: xt-app-splash-bg-in 720ms cubic-bezier(0.16, 1, 0.3, 1) 80ms forwards;
  }
  @keyframes xt-app-splash-bg-in {
    to { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    #xt-app-splash-bg { display: none; }
  }
  :root[data-perf-mode="on"] #xt-app-splash-bg { display: none; }

  .xt-app-splash__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .xt-app-splash__mark-wrap {
    position: relative;
    display: grid;
    place-items: center;
    box-sizing: content-box;
    padding: 0 1.5rem;
    width: clamp(6.5rem, 18vmin, 9rem);
    aspect-ratio: 1 / 1;
  }

  .xt-app-splash__svg {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    overflow: visible;
    animation: xt-app-splash-mark-in 640ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .xt-app-splash__base {
    stroke: var(--color-accent);
    stroke-width: 0.27;
    opacity: 0.55;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  @media (prefers-reduced-motion: reduce) {
    .xt-app-splash__base {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
    }
  }
  .xt-app-splash__comet {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
    animation: xt-app-splash-comet-in 320ms ease-out 800ms backwards;
  }
  @keyframes xt-app-splash-comet-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .xt-app-splash__wordmark {
    font-size: clamp(1.125rem, 2.6vmin, 1.5rem);
    letter-spacing: -0.02em;
    display: inline-flex;
    align-items: baseline;
    animation: xt-app-splash-word-in 480ms cubic-bezier(0.16, 1, 0.3, 1) 980ms backwards;
  }
  .xt-app-splash__wordmark-1 {
    font-weight: 500;
    color: var(--color-fg);
  }
  .xt-app-splash__wordmark-2 {
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    margin-left: 0.08em;
  }

  @keyframes xt-app-splash-mark-in {
    from { opacity: 0; transform: scale(0.94) translateY(6px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes xt-app-splash-word-in {
    from { opacity: 0; transform: translateY(6px); letter-spacing: 0.04em; }
    to   { opacity: 1; transform: translateY(0); letter-spacing: -0.02em; }
  }

  :root[data-perf-mode="on"] #xt-app-splash {
    transition: none;
    background: var(--color-bg);
  }
  :root[data-perf-mode="on"] .xt-app-splash__svg,
  :root[data-perf-mode="on"] .xt-app-splash__wordmark {
    animation: none;
  }
  :root[data-perf-mode="on"] .xt-app-splash__base {
    stroke-dasharray: none;
    stroke-dashoffset: 0;
  }
  :root[data-perf-mode="on"] .xt-app-splash__comet { display: none; }
</style>

<script>
  import "@/scripts/spatial-navigation"
  import { initFocusGlide } from "@/scripts/lib/focus-glide.js"
  import { initKeyboardHelp } from "@/scripts/lib/keyboard-help.js"
  import { initI18n } from "@/scripts/lib/i18n.js"
  import { initConnectivity } from "@/scripts/lib/connectivity.js"
  import { initTrayHandler } from "@/scripts/lib/tray-handler"
  import { setupSplashBackdrop } from "@/scripts/lib/splash-backdrop"
  import { setupSplashComet } from "@/scripts/lib/splash-comet"
  initI18n()
  initConnectivity()

  ;(function dismissSplash() {
    if (document.documentElement.hasAttribute("data-splash-done")) return
    const splash = document.getElementById("xt-app-splash")
    if (!splash) return

    const backdropCleanup = setupSplashBackdrop(splash)
    const cometCleanup = setupSplashComet(splash)

    const infinityPath = splash.querySelector(
      "#xt-app-splash-path"
    ) as SVGPathElement | null
    let pathLen = 0
    if (infinityPath) {
      try { pathLen = infinityPath.getTotalLength() } catch {}
    }
    if (infinityPath && pathLen > 0) {
      const reduce =
        window.matchMedia("(prefers-reduced-motion: reduce)").matches ||
        document.documentElement.getAttribute("data-perf-mode") === "on"
      if (reduce) {
        infinityPath.style.strokeDasharray = "none"
        infinityPath.style.strokeDashoffset = "0"
      } else {
        infinityPath.style.strokeDasharray = `${pathLen}`
        infinityPath.style.strokeDashoffset = `${pathLen}`
        infinityPath.animate(
          [{ strokeDashoffset: `${pathLen}` }, { strokeDashoffset: "0" }],
          {
            duration: 800,
            delay: 200,
            easing: "cubic-bezier(0.16, 1, 0.3, 1)",
            fill: "forwards",
          }
        )
      }
    }

    const MIN_DISPLAY_MS = 3000
    const start = performance.now()
    const remove = () => {
      cometCleanup()
      backdropCleanup()
      document.documentElement.setAttribute("data-splash-done", "")
      try { sessionStorage.setItem("xt_splash_done", "1") } catch {}
      splash.remove()
    }
    const finish = () => {
      const elapsed = performance.now() - start
      const wait = Math.max(0, MIN_DISPLAY_MS - elapsed)
      setTimeout(() => {
        const skipAnim =
          window.matchMedia("(prefers-reduced-motion: reduce)").matches ||
          document.documentElement.getAttribute("data-perf-mode") === "on"
        if (skipAnim) {
          remove()
          return
        }
        splash.setAttribute("data-hiding", "true")
        let removed = false
        splash.addEventListener(
          "transitionend",
          () => { if (!removed) { removed = true; remove() } },
          { once: true }
        )
        setTimeout(() => { if (!removed) { removed = true; remove() } }, 600)
      }, wait)
    }
    if (document.readyState === "complete") finish()
    else window.addEventListener("load", finish, { once: true })
  })()
  const SpatialNavigation = window.SpatialNavigation

  console.log(
    "%c∞ Extreme InfiniTV%c\nCurious? Source: https://github.com/infinitel8p/Extreme-InfiniTV",
    "color: oklch(0.78 0.15 330); font: 600 1rem/1 ui-sans-serif, system-ui;",
    "color: oklch(0.6 0.011 250); font: 0.75rem/1.4 ui-sans-serif, system-ui;"
  )

  const onLogin = () =>
    location.pathname === "/login" || location.pathname.startsWith("/login/")
  if (!onLogin()) {
    import("@/scripts/expiration.js").then((m) => m.injectExpirationDate?.())
  }
  document.addEventListener("xt:active-changed", () => {
    if (onLogin()) return
    import("@/scripts/expiration.js").then((m) => m.injectExpirationDate?.())
  })

  document.addEventListener("keydown", (ev) => {
    if (!(ev.metaKey || ev.ctrlKey) || ev.key.toLowerCase() !== "k") return
    ev.preventDefault()
    if (location.pathname === "/search" || location.pathname.startsWith("/search/")) {
      const input = document.querySelector(
        'main input[type="search"]'
      )
      if (input) {
        input.focus()
        input.select?.()
      }
      return
    }
    location.href = "/search"
  })

  initFocusGlide()
  initKeyboardHelp()
  initTrayHandler()

  // -----------------------------------------------------------------------
  // Discord idle presence: push "Browsing the catalog" on every page load
  // -----------------------------------------------------------------------
  function pageArea() {
    const pathname = location.pathname || "/"
    if (pathname === "/" || pathname === "") return "the hub"
    if (pathname.startsWith("/livetv")) return "Live TV"
    if (pathname.startsWith("/movies")) return "Movies"
    if (pathname.startsWith("/series")) return "Series"
    if (pathname.startsWith("/epg")) return "the EPG grid"
    if (pathname.startsWith("/search")) return "Search"
    if (pathname.startsWith("/favorites")) return "Favorites"
    if (pathname.startsWith("/recently-added")) return "Recently Added"
    if (pathname.startsWith("/downloads")) return "Downloads"
    if (pathname.startsWith("/settings")) return "Settings"
    return "the catalog"
  }

  async function pushIdlePresence() {
    if (onLogin()) return
    try {
      const [{ setIdleRichPresence }, { getActiveEntry }] = await Promise.all([
        import("@/scripts/lib/discord-rpc.js"),
        import("@/scripts/lib/creds.js"),
      ])
      const active = await getActiveEntry()
      setIdleRichPresence({
        playlistId: active?._id || "",
        playlistTitle: active?.title || "",
        area: pageArea(),
      }).catch(() => {})
    } catch {}
  }
  pushIdlePresence()
  document.addEventListener("xt:active-changed", pushIdlePresence)

  let lastPruneAt = 0
  const PRUNE_THROTTLE_MS = 5_000
  async function pruneDownloadsIfStale() {
    if (onLogin()) return
    if (Date.now() - lastPruneAt < PRUNE_THROTTLE_MS) return
    lastPruneAt = Date.now()
    try {
      const { pruneMissingDownloads } = await import(
        "@/scripts/lib/downloads.js"
      )
      await pruneMissingDownloads()
    } catch {}
  }
  pruneDownloadsIfStale()
  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "visible") pruneDownloadsIfStale()
  })
  window.addEventListener("focus", pruneDownloadsIfStale)

  window.addEventListener("load", function () {
    let snReady = false
    const initSpatialNav = () => {
      if (snReady) return
      snReady = true
      SpatialNavigation.init()
      SpatialNavigation.add({
        id: "main",
        selector:
          "a, button, summary, input, textarea, [contenteditable='true'], select, [tabindex]:not([tabindex='-1'])",
      })
      SpatialNavigation.makeFocusable()
    }
    if (typeof window.requestIdleCallback === "function") {
      window.requestIdleCallback(initSpatialNav, { timeout: 2000 })
    } else {
      setTimeout(initSpatialNav, 500)
    }

    const ARROWS = new Set([
      "ArrowUp",
      "ArrowDown",
      "ArrowLeft",
      "ArrowRight",
    ])
    const onFirstArrow = (e) => {
      if (!ARROWS.has(e.key)) return
      initSpatialNav()
      const active = document.activeElement
      if (!active || active === document.body) {
        e.preventDefault()
        SpatialNavigation.focus()
      }
      document.removeEventListener("keydown", onFirstArrow, true)
    }
    document.addEventListener("keydown", onFirstArrow, true)
  })
</script>
