---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/SearchInput.astro";
import SortMenu from "@/components/SortMenu.astro";
import CategoryPickerDialog from "@/components/CategoryPickerDialog.astro";
import { IconChevronDown } from "@tabler/icons-svelte";
---

<Layout pageTitle="Movies">
	<main
		class="w-full max-w-480 mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 md:landscape:pt-6 pb-6
			flex flex-col gap-4 flex-1 min-h-0">

		<header class="route-hero shrink-0">
			<h1 data-i18n="page.movies.title" class="route-hero__title">Movies</h1>
			<div class="route-hero__meta">
				<span><strong id="movie-hero-count">-</strong> <span data-i18n="list.inCatalogue">in catalogue</span></span>
				<span class="route-hero__meta-divider" aria-hidden="true"></span>
				<span id="movie-hero-cat" class="truncate min-w-0">All categories</span>
			</div>
		</header>

		<!-- Toolbar: category + search -->
		<section class="flex flex-col sm:flex-row gap-3 shrink-0">
			<button
				id="movie-category-picker-trigger"
				type="button"
				aria-haspopup="dialog"
				aria-controls="movie-category-picker-dialog"
				class="rounded-xl border border-line bg-surface px-3.5 py-2 min-h-11 text-sm flex items-center gap-2 text-left
					sm:w-72 lg:w-80 shrink-0
					hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent transition-colors">
				<span data-i18n="list.category" class="text-fg-3 shrink-0">Category</span>
				<span
					id="movie-category-picker-label"
					data-i18n="list.allCategories"
					class="text-fg truncate flex-1">All categories</span>
				<IconChevronDown
					aria-hidden="true"
					stroke={2}
					class="size-4 text-fg-3 shrink-0"
				/>
			</button>

			<div class="flex-1 min-w-0">
				<SearchInput
					id="movie-search"
					label="Search movies"
					placeholder="Search movies…"
					labelKey="list.searchMovies"
					placeholderKey="list.searchMoviesPlaceholder"
				/>
			</div>

			<SortMenu
				id="movie-sort"
				widthClass="sm:w-44 shrink-0"
				options={[
					{ value: "default", label: "Default", key: "sort.default" },
					{ value: "added", label: "Recently added", key: "sort.recentlyAdded" },
					{ value: "az", label: "A-Z", key: "sort.az" },
				]}
			/>
		</section>

		<!-- Status row -->
		<div
			id="movie-list-status"
			data-i18n="list.noPlaylistSelected"
			class="px-1 text-xs text-fg-3 tabular-nums shrink-0">
			No playlist selected.
		</div>

		<!-- Poster grid. -->
		<section
			id="movie-grid"
			class="flex-1 min-h-0 overflow-auto custom-scroll
				grid gap-3 sm:gap-4
				grid-cols-[repeat(auto-fill,minmax(8rem,1fr))]
				sm:grid-cols-[repeat(auto-fill,minmax(10rem,1fr))]
				lg:grid-cols-[repeat(auto-fill,minmax(11rem,1fr))]
				auto-rows-min content-start
				p-2 pb-4">
			<!-- Cards rendered by movies.js -->
		</section>

		<!-- Categories popover -->
		<CategoryPickerDialog idPrefix="movie-category-picker" />

		<div
			id="app-version"
			class="fixed bottom-[max(0.5rem,env(safe-area-inset-bottom))] right-[max(0.75rem,env(safe-area-inset-right))] text-2xs text-fg-3 opacity-70 tabular-nums pointer-events-none">
			Loading…
		</div>
	</main>

	<script>
		import "@/scripts/movies/movies.ts";
		import "@/scripts/updater-startup.js";
		import { injectVersion } from "@/scripts/version.js";
		injectVersion();
	</script>
</Layout>
