---
import Layout from "@/layouts/Layout.astro"
---

<Layout pageTitle="Documentation">
  <main class="flex flex-1 min-h-0 flex-col">
    <noscript>
      <p class="m-4 text-sm text-fg-2">
        Documentation requires JavaScript and a network connection. Open it directly at
        <a class="underline" href="https://egennusoF2.github.io/LelegIPTV/" target="_blank" rel="noopener">egennusoF2.github.io/LelegIPTV</a>.
      </p>
    </noscript>
    <div id="xt-docs-skeleton" class="xt-docs-skeleton grid flex-1 place-items-center text-fg-3 text-sm">
      <span data-i18n="docs.loading">Loading documentation…</span>
    </div>
    <iframe
      id="xt-docs-frame"
      title="Leleg IPTV documentation"
      data-i18n-attr="title:docs.frameTitle"
      class="hidden flex-1 w-full border-0 bg-bg"
      referrerpolicy="no-referrer"
      sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox"
    ></iframe>
  </main>

  <script is:inline>
    (() => {
      const DOCS_BASE = "https://egennusoF2.github.io/LelegIPTV"
      const DOCS_ORIGIN = "https://egennusoF2.github.io"
      const iframe = document.getElementById("xt-docs-frame")
      const skeleton = document.getElementById("xt-docs-skeleton")
      if (!(iframe instanceof HTMLIFrameElement)) return

      const preconnect = document.createElement("link")
      preconnect.rel = "preconnect"
      preconnect.href = DOCS_ORIGIN
      preconnect.crossOrigin = ""
      document.head.appendChild(preconnect)

      const sanitizePath = (raw) => {
        if (!raw) return ""
        const cleaned = raw.replace(/[^a-zA-Z0-9/_-]/g, "")
        const noLead = cleaned.replace(/^\/+/, "")
        return noLead.endsWith("/") || noLead === "" ? noLead : noLead + "/"
      }

      const resolveTheme = () => {
        const stored = localStorage.getItem("xt_theme") || "dark"
        if (stored === "light" || stored === "dark") return stored
        return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
      }

      const buildSrc = () => {
        const params = new URLSearchParams(window.location.search)
        const path = sanitizePath(params.get("p") || "")
        const url = new URL(`${DOCS_BASE}/${path}`)
        url.searchParams.set("embed", "1")
        url.searchParams.set("theme", resolveTheme())
        return url.toString()
      }

      iframe.addEventListener("load", () => {
        if (skeleton) skeleton.classList.add("hidden")
        iframe.classList.remove("hidden")
      })

      iframe.src = buildSrc()

      const pushTheme = () => {
        try {
          iframe.contentWindow?.postMessage(
            { type: "xt-docs:theme", theme: resolveTheme() },
            DOCS_ORIGIN
          )
        } catch {}
      }
      window.addEventListener("storage", (event) => {
        if (event.key === "xt_theme") pushTheme()
      })
      const systemMql = window.matchMedia("(prefers-color-scheme: dark)")
      systemMql.addEventListener?.("change", pushTheme)
    })()
  </script>
</Layout>

<style>
  #xt-docs-frame {
    color-scheme: light dark;
  }
  .xt-docs-skeleton {
    animation: xt-docs-skeleton-pulse 1.6s ease-in-out infinite;
  }
  @keyframes xt-docs-skeleton-pulse {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 0.9; }
  }
  @media (prefers-reduced-motion: reduce) {
    .xt-docs-skeleton { animation: none; opacity: 0.7; }
  }
  :root[data-perf-mode="on"] .xt-docs-skeleton {
    animation: none;
    opacity: 0.7;
  }
</style>
