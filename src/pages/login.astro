	function setPickedLocal(picked) {
		pickedLocal = picked;
		if (picked) {
			localFileNameEl.removeAttribute("data-i18n");
			localFileNameEl.textContent = picked.name;
			localFileNameEl.classList.remove("text-fg-3");
			localFileNameEl.classList.add("text-fg-2");
		} else {
			localFileNameEl.setAttribute("data-i18n", "login.field.localFile.none");
			localFileNameEl.textContent = t("login.field.localFile.none");
			localFileNameEl.classList.remove("text-fg-2");
			localFileNameEl.classList.add("text-fg-3");
