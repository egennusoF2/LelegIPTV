	function looksLikeM3U(text) {
		const head = (text || "").slice(0, 4096);
		return head.includes("#EXTM3U") || /#EXTINF\s*:/i.test(head);
	}

	async function pickLocalViaTauri() {
		const { open } = await import("@tauri-apps/plugin-dialog");
		const picked = await open({
			multiple: false,
			directory: false,
			filters: [{ name: "M3U playlist", extensions: ["m3u", "m3u8"] }],
		});
		if (!picked || typeof picked !== "string") return null;
		const fs = await import("@tauri-apps/plugin-fs");
		try {
			const stat = await fs.stat(picked);
			if (stat?.size && stat.size > MAX_LOCAL_M3U_BYTES) {
				showStatus("unavailable", t("login.status.localTooLarge", { size: stat.size.toLocaleString() }));
				return null;
			}
		} catch {}
		const text = await fs.readTextFile(picked);
		const slash = Math.max(picked.lastIndexOf("/"), picked.lastIndexOf("\\"));
		const name = slash >= 0 ? picked.slice(slash + 1) : picked;
		return { name, text };
	}

	async function readPickedFile(file) {
		if (!file) return null;
		if (file.size > MAX_LOCAL_M3U_BYTES) {
			showStatus("unavailable", t("login.status.localTooLarge", { size: file.size.toLocaleString() }));
			return null;
		}
		const text = await file.text();
		return { name: file.name, text };
	}

	localPickBtn.addEventListener("click", async () => {
		clearStatus();
		localPickBtn.disabled = true;
		try {
			let picked = null;
			if (isAndroidFsActive()) {
				try {
					picked = await pickM3UFile({ maxBytes: MAX_LOCAL_M3U_BYTES });
				} catch (err) {
					log.warn("[xt:login] android-fs picker failed, falling back:", err);
				}
			} else if (isTauri) {
				try {
					picked = await pickLocalViaTauri();
				} catch (err) {
					log.warn("[xt:login] tauri file picker failed, falling back:", err);
				}
			}
			if (!picked) {
				localFileInput.value = "";
				localFileInput.click();
				return;
			}
			if (picked.oversize || (picked.size && picked.size > MAX_LOCAL_M3U_BYTES)) {
				const oversizeBytes = picked.size || picked.text?.length || 0;
				showStatus("unavailable", t("login.status.localTooLarge", { size: oversizeBytes.toLocaleString() }));
				return;
			}
			if (picked.text && picked.text.length > MAX_LOCAL_M3U_BYTES) {
				showStatus("unavailable", t("login.status.localTooLarge", { size: picked.text.length.toLocaleString() }));
				return;
			}
			finalizePickedFile(picked);
		} finally {
			localPickBtn.disabled = false;
		}
	});

	localFileInput.addEventListener("change", async () => {
		const file = localFileInput.files?.[0];
		if (!file) return;
		const picked = await readPickedFile(file);
		localFileInput.value = "";
		if (picked) finalizePickedFile(picked);
	});

	function finalizePickedFile(picked) {
		if (!picked || !picked.text) {
			showStatus("unavailable", t("login.status.localEmpty"));
			setPickedLocal(null);
			return;
		}
		if (!looksLikeM3U(picked.text)) {
			showStatus("unavailable", t("login.status.localNotM3u"));
			setPickedLocal(null);
			return;
		}
		const parsed = parseM3U(picked.text);
		const count = parsed.entries.length;
		setPickedLocal(picked);
		if (!titleEl.value.trim()) {
			titleEl.value = picked.name.replace(/\.(m3u8?|M3U8?)$/, "");
		}
		showStatus(
			"active",
			t("login.status.playlistOk") +
				(count
					? t("login.status.playlistEntries", { count: count.toLocaleString() })
					: ".")
		);
	}

	serverEl.addEventListener("input", () => {
		const parsed = parseXtreamUrl(serverEl.value.trim());
		if (parsed) {
			serverEl.value = parsed.serverUrl;
			if (!userEl.value) userEl.value = parsed.username;
			if (!passEl.value) passEl.value = parsed.password;
			showStatus("info", t("login.status.credentialsExtracted"));
		}
	});

	function clearStatus() {
		statusEl.classList.add("hidden");
		statusEl.classList.remove("flex");
		statusEl.innerHTML = "";
	}

	function showStatus(kind, message) {
		const wasHidden = statusEl.classList.contains("hidden");
		statusEl.classList.remove("hidden");
		statusEl.classList.add("flex");
		// Reset palette classes, then apply.
		statusEl.className =
			"flex items-start gap-2.5 rounded-xl border px-3.5 py-2.5 text-sm leading-relaxed ";
		const palette = {
			info: "border-accent/30 bg-accent-soft text-accent",
			active: "border-ok/30 bg-ok/10 text-ok",
			expired: "border-warn/30 bg-warn/10 text-warn",
			inactive: "border-warn/30 bg-warn/10 text-warn",
			unavailable: "border-bad/30 bg-bad/10 text-bad",
			busy: "border-line bg-surface text-fg-2",
		};
		statusEl.className += palette[kind] || palette.info;
		// `mt-2` (8px) lines the dot up with the first-line optical centre for
		// `text-sm leading-relaxed` (line-height ~22.75px). The earlier `mt-1.5`
		// looked too high on single-line messages.
		const dot = `<span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 rounded-full bg-current shrink-0"></span>`;
		const isMultiline = typeof message === "string" && message.includes("\n");
		const bodyClass = isMultiline ? ' class="whitespace-pre-line"' : "";
		statusEl.innerHTML = `${dot}<span${bodyClass}>${escapeText(message)}</span>`;
		if (wasHidden) {
			statusEl.classList.remove("status-enter");
			void statusEl.offsetWidth;
			statusEl.classList.add("status-enter");
		}
	}

	function escapeText(s) {
		const d = document.createElement("div");
		d.textContent = s;
		return d.innerHTML;
	}

	function isPrivateHost(host) {
		return (
			/^10\./.test(host) ||
			/^192\.168\./.test(host) ||
			/^172\.(1[6-9]|2\d|3[01])\./.test(host) ||
			host === "localhost" ||
			host.endsWith(".local")
		);
	}

	function privateHostHint(rawUrl) {
		try {
			const u = new URL(rawUrl);
			if (!isTauri && isPrivateHost(u.hostname)) {
				return " " + t("login.status.privateHostHint");
			}
		} catch {}
		return "";
	}

	function describeCandidateResult(result, serverUrl) {
		const exp = result.expDate
			? t("login.status.expiresOn", { date: new Date(result.expDate).toLocaleDateString() })
			: "";
		switch (result.status) {
			case "active":
				return t("login.status.connected") + exp;
			case "expired":
				return t("login.status.expired") + exp;
			case "inactive":
				return t("login.status.inactive") + exp;
			default: {
				// Map the structured reason from classifyError to actionable copy
				const reasonKeyMap = {
					unreachable: "login.status.unreachable",
					timeout: "login.status.timeout",
					cors: "login.status.corsBlocked",
					auth_rejected: "login.status.badCredentials",
					not_found: "login.status.notFound",
					rate_limited: "login.status.rateLimited",
					server_error: "login.status.httpError",
					http_error: "login.status.httpError",
					bad_response: "login.status.badResponseXtream",
					unknown: "login.status.serverUnreachable",
				};
				const reasonKey = (result.reason && reasonKeyMap[result.reason]) || "login.status.serverUnreachable";
				const params = result.httpStatus != null ? { status: String(result.httpStatus) } : {};
				return t(reasonKey, params) + privateHostHint(serverUrl);
			}
		}
	}

	function describeResolvedCandidate(resolved) {
		const base = describeCandidateResult(resolved.test, resolved.serverUrl);
		if (!resolved.swapped) return base;
		const noteKey = resolved.scheme === "http"
			? "login.status.schemeSwappedHttp"
			: "login.status.schemeSwappedHttps";
		return base + " " + t(noteKey);
	}

	function reflectResolvedUrls(primaryResolved, mirrorResolveds) {
		if (primaryResolved && serverEl.value.trim() !== primaryResolved.serverUrl) {
			serverEl.value = primaryResolved.serverUrl;
		}
		const rows = mirrorsListEl?.querySelectorAll("[data-role='mirror-row']") || [];
		let mirrorIdx = 0;
		for (const row of rows) {
			const serverInput = /** @type {HTMLInputElement} */ (row.querySelector("[data-role='mirror-server']"));
			if (!serverInput || !serverInput.value.trim()) continue;
			const resolved = mirrorResolveds[mirrorIdx++];
			if (resolved && serverInput.value.trim() !== resolved.serverUrl) {
				serverInput.value = resolved.serverUrl;
			}
		}
	}

	// Rank candidate verdicts: active > expired > inactive > unavailable.
	function statusRank(status) {
		if (status === "active") return 3;
		if (status === "expired") return 2;
		if (status === "inactive") return 1;
		return 0;
	}

	testBtn.addEventListener("click", async () => {
		testBtn.disabled = true;
		try {
			if (mode === "xtream") {
				const serverUrl = serverEl.value.trim();
				const username = userEl.value.trim();
				const password = passEl.value.trim();
				if (!serverUrl || !username || !password) {
					showStatus(
						"unavailable",
						t("login.status.fillFields")
					);
					return;
				}
				const candidates = [
					{ label: t("login.mirrors.primaryLabel"), serverUrl, username, password },
					...readMirrorsFromForm().map((mirror, idx) => ({
						label: t("login.mirrors.candidateLabel", { n: idx + 1 }),
						...mirror,
					})),
				];
				showStatus("busy", t("login.status.testing"));
				const resolveds = await Promise.all(
					candidates.map((cand) =>
						resolveServerScheme({
							serverUrl: cand.serverUrl,
							username: cand.username,
							password: cand.password,
						})
					)
				);
				reflectResolvedUrls(resolveds[0], resolveds.slice(1));
				const results = resolveds.map((resolved) => resolved.test);

				// Single-candidate path keeps the old single-line message.
				if (candidates.length === 1) {
					const result = results[0];
					showStatus(
						result.status === "active" ? "active"
							: result.status === "expired" ? "expired"
							: result.status === "inactive" ? "inactive"
							: "unavailable",
						describeResolvedCandidate(resolveds[0])
					);
				} else {
					// Aggregate verdict = best candidate. Body lists each.
					let bestRank = -1;
					let bestStatus = "unavailable";
					for (const result of results) {
						const rank = statusRank(result.status);
						if (rank > bestRank) {
							bestRank = rank;
							bestStatus = result.status === "unavailable" ? "unavailable" : result.status;
						}
					}
					const lines = candidates.map((cand, idx) =>
						`${cand.label}: ${describeResolvedCandidate(resolveds[idx])}`
					);
					showStatus(bestStatus, lines.join("\n"));
				}
			} else {
				const rawUrl = m3uEl.value.trim();
				if (!rawUrl) {
					showStatus("unavailable", t("login.status.enterM3uUrl"));
					return;
				}
				showStatus("busy", t("login.status.fetching"));
				const resolved = await resolveM3UScheme(rawUrl);
				if (m3uEl.value.trim() !== resolved.url) m3uEl.value = resolved.url;
				const result = resolved.test;
				if (result.status === "active") {
					const count = result.count || 0;
					const swap = resolved.swapped
						? " " + t(resolved.scheme === "http" ? "login.status.schemeSwappedHttp" : "login.status.schemeSwappedHttps")
						: "";
					showStatus(
						"active",
						t("login.status.playlistOk") + (count ? t("login.status.playlistEntries", { count: count.toLocaleString() }) : ".") + swap
					);
				} else {
					const reasonKeyMap = {
						unreachable: "login.status.unreachable",
						timeout: "login.status.timeout",
						cors: "login.status.corsBlocked",
						not_found: "login.status.notFound",
						rate_limited: "login.status.rateLimited",
						server_error: "login.status.httpError",
						http_error: "login.status.httpError",
						bad_response: "login.status.badResponseM3U",
						unknown: "login.status.playlistFetchFailed",
					};
					const reasonKey = (result.reason && reasonKeyMap[result.reason]) || "login.status.playlistFetchFailed";
					const params = result.httpStatus != null ? { status: String(result.httpStatus) } : {};
					showStatus("unavailable", t(reasonKey, params) + privateHostHint(resolved.url));
				}
			}
			// After any Test result (success or failure), reveal the "Run full
			// diagnostic" affordance. Hidden for local-m3u since there's no
			// remote to probe step-by-step.
			if (mode !== "local-m3u") revealDiagnosticAffordance();
		} finally {
			testBtn.disabled = false;
		}
	});

	// Progressive disclosure: simple Test result first, then optional full
	// step-by-step diagnostic on demand. Hidden until the user runs Test at
	// least once (so it doesn't compete with the primary action).
	function revealDiagnosticAffordance() {
		if (!diagnosticAffordance) return;
		diagnosticAffordance.classList.remove("hidden");
		diagnosticAffordance.classList.add("flex");
	}

	function hideDiagnosticResult() {
		if (!diagnosticResultEl) return;
		diagnosticResultEl.classList.add("hidden");
		diagnosticResultEl.replaceChildren();
	}

	// Whenever the user edits any credential field, hide the previous
	// diagnostic result - it's now stale.
	for (const el of [serverEl, userEl, passEl, m3uEl]) {
		el?.addEventListener("input", hideDiagnosticResult);
	}

	diagnosticRunBtn?.addEventListener("click", async () => {
		if (!diagnosticResultEl) return;
		diagnosticRunBtn.setAttribute("disabled", "");
		diagnosticRunBtn.classList.add("opacity-60");
		diagnosticResultEl.classList.remove("hidden");
		diagnosticResultEl.className =
			"flex flex-col gap-2.5 rounded-xl border border-line bg-surface px-3.5 py-3 text-sm leading-relaxed text-fg-2";
		diagnosticResultEl.textContent = t("diagnostic.running");
		try {
			const { runXtreamDiagnostic, runM3UDiagnostic, renderDiagnosticInto } = await import(
				"@/scripts/lib/diagnostic.ts"
			);
			// Re-render the result panel each time a step completes. The Xtream
			// wizard can take 5+ seconds end-to-end (vod + series catalogues
			// can be slow), so users need to see rows appearing or they'll
			// think the app is stuck.
			const onProgress = (partialSteps) => {
				renderDiagnosticInto(diagnosticResultEl, {
					steps: partialSteps,
					verdict: "running",
					verdictMessage: t("diagnostic.running"),
				});
			};
			let result;
			if (mode === "xtream") {
				result = await runXtreamDiagnostic({
					serverUrl: serverEl.value.trim(),
					username: userEl.value.trim(),
					password: passEl.value.trim(),
				}, { onProgress });
			} else if (mode === "m3u") {
				result = await runM3UDiagnostic(m3uEl.value.trim(), { onProgress });
			} else {
				diagnosticResultEl.classList.add("hidden");
				return;
			}
			renderDiagnosticInto(diagnosticResultEl, result);
		} catch (error) {
			diagnosticResultEl.textContent = String(error?.message || error);
		} finally {
			diagnosticRunBtn.removeAttribute("disabled");
			diagnosticRunBtn.classList.remove("opacity-60");
		}
	});

	$("playlist-form").addEventListener("submit", async (e) => {
		e.preventDefault();
		saveBtn.disabled = true;
		try {
			if (!validateEpgUrlInputs()) {
				epgDetails?.setAttribute("open", "");
				showStatus("unavailable", t("login.epg.invalidUrl"));
				return;
			}
			const { primary: epgUrl, additional: additionalEpgUrls } =
				readEpgUrlsFromForm();
			const disableProviderEpg =
				mode === "xtream" ? !!epgDisableProviderEl?.checked : false;
			let savedId = editing?._id || null;
			const epgChanged =
				editing &&
				(editing.epgUrl !== epgUrl ||
					JSON.stringify(editing.additionalEpgUrls || []) !==
						JSON.stringify(additionalEpgUrls) ||
					!!editing.disableProviderEpg !== disableProviderEpg);

			if (mode === "xtream") {
				const rawServerUrl = serverEl.value.trim();
				const username = userEl.value.trim();
				const password = passEl.value.trim();
				if (!rawServerUrl || !username || !password) {
					showStatus(
						"unavailable",
						t("login.status.allRequired")
					);
					return;
				}
				// Resolve scheme for primary + mirrors before persisting so the
				// saved entry always has a usable http(s):// prefix and we don't
				// re-probe on every API call.
				showStatus("busy", t("login.status.testing"));
				const rawMirrors = readMirrorsFromForm();
				const allResolveds = await Promise.all([
					resolveServerScheme({ serverUrl: rawServerUrl, username, password }),
					...rawMirrors.map((mirror) => resolveServerScheme(mirror)),
				]);
				const primaryResolved = allResolveds[0];
				const mirrorResolveds = allResolveds.slice(1);
				reflectResolvedUrls(primaryResolved, mirrorResolveds);
				const serverUrl = primaryResolved.serverUrl;
				const mirrors = rawMirrors.map((mirror, idx) => ({
					serverUrl: mirrorResolveds[idx].serverUrl,
					username: mirror.username,
					password: mirror.password,
				}));
				const liveContainer = liveContainerEl?.value === "ts" ? "ts" : "m3u8";
				const patch = {
					type: "xtream",
					title: titleEl.value.trim() || "",
					serverUrl,
					username,
					password,
					mirrors,
					liveContainer,
					epgUrl,
					additionalEpgUrls,
					disableProviderEpg,
				};
				if (editing) {
					await updateEntry(editing._id, patch);
				} else {
					const saved = await addEntry(patch);
					savedId = saved._id;
				}
			} else if (mode === "m3u") {
				const rawUrl = m3uEl.value.trim();
				if (!rawUrl) {
					showStatus("unavailable", t("login.status.enterM3uUrl"));
					return;
				}
				// Same silent-fallback rule as Xtream: probe both schemes, save
				// whichever the playlist actually serves under, fall back to the
				// typed scheme (or http) when the provider is unreachable.
				showStatus("busy", t("login.status.fetching"));
				const resolvedM3U = await resolveM3UScheme(rawUrl);
				if (m3uEl.value.trim() !== resolvedM3U.url) m3uEl.value = resolvedM3U.url;
				const patch = {
					type: "m3u",
					title: titleEl.value.trim() || "",
					url: resolvedM3U.url,
					epgUrl,
					additionalEpgUrls,
				};
				if (editing) {
					await updateEntry(editing._id, patch);
				} else {
					const saved = await addEntry(patch);
					savedId = saved._id;
				}
			} else {
				if (!pickedLocal || !pickedLocal.text) {
					showStatus("unavailable", t("login.status.localPickFirst"));
					return;
				}
				const parsed = parseM3U(pickedLocal.text);
				const patch = {
					type: "local-m3u",
					title: titleEl.value.trim() || pickedLocal.name.replace(/\.(m3u8?|M3U8?)$/, ""),
					content: pickedLocal.text,
					sourceName: pickedLocal.name,
					// Preserve any user-supplied override
					epgUrl: epgUrl || parsed.epgUrl || "",
					additionalEpgUrls,
				};
				if (editing) {
					await updateEntry(editing._id, patch);
				} else {
					const saved = await addEntry(patch);
					savedId = saved._id;
				}
				if (savedId && parsed.epgUrl) {
					try {
						localStorage.setItem(`xt_m3u_epg:${savedId}`, parsed.epgUrl);
					} catch {}
				}
				if (savedId) {
					try {
						const { warmupActive } = await import("@/scripts/lib/catalog.js");
						await warmupActive(savedId, { force: true });
					} catch (err) {
						log.warn("[xt:login] post-save warmup failed:", err);
					}
				}
			}

			// Force a fresh EPG load on next visit if the user changed any
			// source URL. Drops memCache + per-URL HTTP validators + IDB so
			// the next loadProgrammes() refetches all sources cleanly.
			if (savedId && (epgChanged || !editing)) {
				invalidateEpgPlaylist(savedId);
			}

			location.href = editing ? "/" : "/livetv";
		} finally {
			saveBtn.disabled = false;
		}
	});

	// ---- Boot: prefill for editing, or default to "add Xtream" ----
	if (editingId) {
		const entries = await getEntries();
		editing = entries.find((e) => e._id === editingId) || null;
	}
	if (editing) {
		pageTitle.removeAttribute("data-i18n");
		pageTitle.textContent = t("login.title.edit");
		pageSubtitle.removeAttribute("data-i18n");
		pageSubtitle.textContent = t("login.subtitle.edit", { title: editing.title });
		saveBtn.removeAttribute("data-i18n");
		saveBtn.textContent = t("login.action.saveEdit");
		tabXtream.disabled = editing.type !== "xtream";
		tabM3u.disabled = editing.type !== "m3u";
		tabLocal.disabled = editing.type !== "local-m3u";
		setMode(editing.type);
		titleEl.value = editing.title || "";
		if (epgPrimaryEl) epgPrimaryEl.value = editing.epgUrl || "";
		const additional = Array.isArray(editing.additionalEpgUrls)
			? editing.additionalEpgUrls
			: [];
		for (const url of additional) addEpgRow(url);
		if (epgDisableProviderEl) {
			epgDisableProviderEl.checked = !!editing.disableProviderEpg;
		}
		// Open the disclosure when there's already something to see; keeps it
		// out of the way on fresh-add.
		if (
			editing.epgUrl ||
			additional.length ||
			editing.disableProviderEpg
		) {
			epgDetails?.setAttribute("open", "");
		}
		if (editing.type === "xtream") {
			serverEl.value = editing.serverUrl || "";
			userEl.value = editing.username || "";
			passEl.value = editing.password || "";
			const mirrors = Array.isArray(editing.mirrors) ? editing.mirrors : [];
			for (const mirror of mirrors) addMirrorRow(mirror);
			if (mirrors.length) mirrorsDetails?.setAttribute("open", "");
			if (liveContainerEl) {
				liveContainerEl.value = editing.liveContainer === "ts" ? "ts" : "m3u8";
			}
			if (editing.liveContainer === "ts") {
				xtreamAdvancedDetails?.setAttribute("open", "");
			}
		} else if (editing.type === "m3u") {
			m3uEl.value = editing.url || "";
		} else {
			// local-m3u: surface what was already saved. User can pick a new
			// file to replace it; otherwise we keep the existing content,
			// which lives in IDB (see local-content.js).
			let existingText = "";
			try {
				existingText = await readLocalM3UContent(LOCAL_M3U_SCHEME + editing._id);
			} catch {
				// Storage hiccup - degrade to an empty picker so the user can re-attach the file.
			}
			setPickedLocal({
				name: editing.sourceName || editing.title || "",
				text: existingText,
			});
		}
	} else if (isDemo) {
		pageTitle.setAttribute("data-i18n", "login.title.demo");
		pageTitle.textContent = t("login.title.demo");
		pageSubtitle.setAttribute("data-i18n", "login.subtitle.demo");
		pageSubtitle.textContent = t("login.subtitle.demo");
		setMode("m3u");
		titleEl.value = t("login.demo.title");
		m3uEl.value = DEMO_M3U_URL;
		showStatus("info", t("login.status.demoPrefilled"));
	} else {
		setMode("xtream");
	}
</script>
