	function paintSourceBadge(target, status) {
		if (!target) return;
		target.classList.remove("hidden", "text-bad", "text-good", "text-warn");
		target.removeAttribute("data-i18n");
		if (!status) {
			target.classList.add("hidden");
			target.textContent = "";
			return;
		}
		if (status.status === "ok") {
			target.classList.add("text-good");
			const key = "login.epg.sourceStatusOk";
			target.setAttribute("data-i18n", key);
			target.textContent = t(key, { count: (status.count || 0).toLocaleString() });
		} else {
			target.classList.add("text-bad");
			target.textContent = t("login.epg.sourceStatusError", {
				error: status.error || "Unknown error",
			});
		}
	}

	function applySourceStatuses(detail) {
		if (!editing || !detail || detail.playlistId !== editing._id) return;
		const sources = Array.isArray(detail.sources) ? detail.sources : [];
		if (!sources.length) return;

		const primary = sources.find((source) => source.kind === "primary");
		// Only paint a primary badge when the user has actually set an override.
		if (primary && (epgPrimaryEl?.value || "").trim() === primary.url) {
			paintSourceBadge(epgPrimaryStatus, primary);
		} else {
			paintSourceBadge(epgPrimaryStatus, null);
		}

		const additional = sources.filter((source) => source.kind === "additional");
		const rows = Array.from(
			epgListEl?.querySelectorAll("[data-role='epg-row']") || []
		);
		for (const row of rows) {
			const input = /** @type {HTMLInputElement} */ (row.querySelector("input"));
			const statusEl = row.querySelector("[data-role='epg-row-status']");
			const value = (input?.value || "").trim();
			const match = additional.find((source) => source.url === value);
			paintSourceBadge(statusEl, match || null);
		}
	}

