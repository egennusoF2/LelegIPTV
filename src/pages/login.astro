			const passInput = /** @type {HTMLInputElement} */ (row.querySelector("[data-role='mirror-pass']"));
			const serverUrl = (serverInput?.value || "").trim();
			if (!serverUrl) continue;
			const username = (userInput?.value || "").trim() || primaryUser;
			const password = (passInput?.value || "").trim() || primaryPass;
			if (!username || !password) continue;
			out.push({ serverUrl, username, password });
		}
