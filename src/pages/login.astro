---
import Layout from "@/layouts/Layout.astro";
import { IconArrowLeft, IconChevronDown, IconPlus } from "@tabler/icons-svelte";
---

<Layout pageTitle="Add playlist">
	<main
		class="mx-auto px-5 sm:px-6 lg:px-8 pb-16 pt-4 lg:pt-6 max-w-480 w-full">

		<div>

		<header class="route-hero mb-10">
			<a
				href="/"
				class="self-start inline-flex items-center gap-1.5 text-sm text-fg-3 hover:text-fg focus-visible:text-fg transition-colors min-h-10 -ml-1 mb-2">
				<IconArrowLeft class="h-4 w-4" /> <span data-i18n="common.back">Back</span>
			</a>
			<h1
				id="page-title"
				data-i18n="login.title.add"
				class="route-hero__title">
				Add a playlist
			</h1>
			<p
				id="page-subtitle"
				data-i18n="login.subtitle"
				class="route-hero__sub">
				Connect an Xtream provider, or paste an M3U/M3U8 playlist URL.
			</p>
		</header>


		<!-- Method picker: clean segmented control -->
		<div
			role="tablist"
			aria-label="Playlist type" data-i18n-attr="aria-label:aria.playlistType"
			class="grid grid-cols-3 gap-1 p-1 rounded-xl border border-line bg-surface mb-10">
			<button
				id="tab-xtream"
				type="button"
				role="tab"
				class="flex flex-col items-center justify-center text-center px-3 py-2 rounded-lg min-h-12 transition-colors disabled:cursor-not-allowed disabled:opacity-40">
				<span data-i18n="login.tab.subscription" class="text-sm font-medium leading-tight">
					I have a subscription
				</span>
				<span
					data-i18n="login.tab.subscription.sub"
					class="mt-0.5 text-label font-medium uppercase tracking-wider opacity-70">
					Xtream Codes
				</span>
			</button>
			<button
				id="tab-m3u"
				type="button"
				role="tab"
				class="flex flex-col items-center justify-center text-center px-3 py-2 rounded-lg min-h-12 transition-colors disabled:cursor-not-allowed disabled:opacity-40">
				<span data-i18n="login.tab.url" class="text-sm font-medium leading-tight">
					I have a playlist URL
				</span>
				<span
					data-i18n="login.tab.url.sub"
					class="mt-0.5 text-label font-medium uppercase tracking-wider opacity-70">
					M3U / M3U8
				</span>
			</button>
			<button
				id="tab-local"
				type="button"
				role="tab"
				class="flex flex-col items-center justify-center text-center px-3 py-2 rounded-lg min-h-12 transition-colors disabled:cursor-not-allowed disabled:opacity-40">
				<span data-i18n="login.tab.local" class="text-sm font-medium leading-tight">
					I have a playlist file
				</span>
				<span
					data-i18n="login.tab.local.sub"
					class="mt-0.5 text-label font-medium uppercase tracking-wider opacity-70">
					.m3u / .m3u8
				</span>
			</button>
		</div>

		<form
			id="playlist-form"
			class="flex flex-col gap-6"
			autocomplete="off">
			<label class="flex flex-col gap-2">
				<span
					data-i18n="login.field.title"
					class="text-xs font-semibold tracking-wider uppercase text-fg-3">
					Title
				</span>
				<input
					id="title"
					type="text"
					placeholder="e.g. Living room TV"
					data-i18n-attr="placeholder:login.field.title.placeholder"
					class="field-input"
				/>
				<span data-i18n="login.field.title.helper" class="text-xs text-fg-3 leading-relaxed"
					>Optional name for this playlist.</span
				>
			</label>

			<!-- Xtream fields -->
			<div id="xtream-fields" class="flex flex-col gap-6">
				<label class="flex flex-col gap-2">
					<span
						data-i18n="login.field.serverUrl"
						class="text-xs font-semibold tracking-wider uppercase text-fg-3">
						Server URL
					</span>
					<input
						id="serverUrl"
						type="text"
						placeholder="example.com:8080"
						class="field-input"
					/>
					<span data-i18n="login.field.serverUrl.helper" class="text-xs text-fg-3 leading-relaxed">
						Paste a full player_api.php URL to auto-fill the fields below, or enter just the hostname.
					</span>
				</label>

				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
					<label class="flex flex-col gap-2">
						<span
							data-i18n="login.field.username"
							class="text-xs font-semibold tracking-wider uppercase text-fg-3">
							Username
						</span>
						<input
							id="username"
							type="text"
							autocapitalize="off"
							spellcheck="false"
							class="field-input"
						/>
					</label>
					<label class="flex flex-col gap-2">
						<span
							data-i18n="login.field.password"
							class="text-xs font-semibold tracking-wider uppercase text-fg-3">
							Password
						</span>
						<input
							id="password"
							type="password"
							class="field-input"
						/>
					</label>
				</div>

				<!-- Backup domains (Xtream only). Same disclosure pattern as the
				     EPG sources block below so both advanced sections feel like
				     one family. -->
				<details id="mirrors-section" class="group rounded-xl border border-line bg-surface">
					<summary
						class="flex items-center justify-between gap-3 px-4 py-3 cursor-pointer
							hover:bg-surface-2 focus-visible:bg-surface-2 transition-colors rounded-xl
							list-none min-h-12">
						<span class="flex flex-col gap-0.5 min-w-0">
							<span data-i18n="login.mirrors.toggle" class="text-sm font-medium text-fg">
								Backup domains (optional)
							</span>
							<span
								data-i18n="login.mirrors.helper"
								class="text-xs text-fg-3 leading-relaxed">
								Providers often give a couple of domains. We'll fall back automatically when the primary stops responding.
							</span>
						</span>
						<IconChevronDown
							aria-hidden="true"
							stroke={2}
							class="size-4 shrink-0 text-fg-3 transition-[transform,color] duration-200
								group-open:rotate-180 group-open:text-accent"
						/>
					</summary>

					<div class="flex flex-col gap-3 px-4 pb-4 pt-1">
						<ul id="mirrorsList" class="flex flex-col gap-3"></ul>
						<button
							id="mirrorsAddBtn"
							type="button"
							class="self-start inline-flex items-center gap-1.5 rounded-lg border border-line bg-bg px-3 py-1.5 text-sm text-fg-2
								hover:bg-surface-2 hover:text-fg focus-visible:bg-surface-2 focus-visible:border-accent transition-colors">
							<IconPlus aria-hidden="true" stroke={2} class="size-3.5" />
							<span data-i18n="login.mirrors.add">Add backup domain</span>
						</button>
					</div>
				</details>

				<!-- Advanced: live stream format (Xtream only). Most providers
				     accept either; Dispatcharr only serves .ts today. -->
				<details id="xtream-advanced" class="group rounded-xl border border-line bg-surface">
					<summary
						class="flex items-center justify-between gap-3 px-4 py-3 cursor-pointer
							hover:bg-surface-2 focus-visible:bg-surface-2 transition-colors rounded-xl
							list-none min-h-12">
						<span class="flex flex-col gap-0.5 min-w-0">
							<span data-i18n="login.advanced.toggle" class="text-sm font-medium text-fg">
								Advanced playback (optional)
							</span>
							<span
								data-i18n="login.advanced.helper"
								class="text-xs text-fg-3 leading-relaxed">
								Tweak how stream URLs are built. Only change if your provider needs it.
							</span>
						</span>
						<IconChevronDown
							aria-hidden="true"
							stroke={2}
							class="size-4 shrink-0 text-fg-3 transition-[transform,color] duration-200
								group-open:rotate-180 group-open:text-accent"
						/>
					</summary>

					<div class="flex flex-col gap-3 px-4 pb-4 pt-1">
						<label class="flex flex-col gap-2">
							<span
								data-i18n="login.field.liveContainer"
								class="text-eyebrow font-medium uppercase text-fg-3">
								Live stream format
							</span>
							<select id="liveContainer" class="field-input">
								<option value="m3u8" data-i18n="login.field.liveContainer.option.m3u8">
									HLS (.m3u8)
								</option>
								<option value="ts" data-i18n="login.field.liveContainer.option.ts">
									MPEG-TS (.ts)
								</option>
							</select>
							<span data-i18n="login.field.liveContainer.helper" class="text-xs text-fg-3 leading-relaxed">
								Most providers use HLS. Switch to MPEG-TS only if your provider can't serve .m3u8.
							</span>
						</label>
					</div>
				</details>
			</div>

			<!-- M3U fields -->
			<div id="m3u-fields" class="hidden flex-col gap-6">
				<label class="flex flex-col gap-2">
					<span
						data-i18n="login.field.playlistUrl"
						class="text-xs font-semibold tracking-wider uppercase text-fg-3">
						Playlist URL
					</span>
					<input
						id="m3uUrl"
						type="text"
						placeholder="example.com/playlist.m3u8"
						class="field-input"
					/>
					<span data-i18n="login.field.playlistUrl.helper" class="text-xs text-fg-3 leading-relaxed">
						Any URL that serves an M3U playlist. Extension and scheme optional.
					</span>
				</label>
			</div>

			<!-- Local-file fields -->
			<div id="local-fields" class="hidden flex-col gap-6">
				<label class="flex flex-col gap-2">
					<span
						data-i18n="login.field.localFile"
						class="text-xs font-semibold tracking-wider uppercase text-fg-3">
						Playlist file
					</span>
					<div class="flex flex-wrap items-center gap-3">
						<button
							id="localPickBtn"
							type="button"
							data-i18n="login.action.pickFile"
							class="btn">
							Choose file…
						</button>
						<span
							id="localFileName"
							class="truncate text-sm text-fg-3 font-mono min-w-0"
							data-i18n="login.field.localFile.none"
							>No file selected.</span>
					</div>
					<span data-i18n="login.field.localFile.helper" class="text-xs text-fg-3 leading-relaxed">
						Pick a .m3u or .m3u8 file from your device. The contents are stored with this playlist so you can keep watching without re-picking the file.
					</span>
					<input
						id="localFileInput"
						type="file"
						accept=".m3u,.m3u8,audio/x-mpegurl,application/vnd.apple.mpegurl"
						class="hidden"
					/>
				</label>
			</div>

			<!-- Advanced: EPG sources (collapsed by default) -->
			<details id="epg-sources" class="group rounded-xl border border-line bg-surface">
				<summary
					class="flex items-center justify-between gap-3 px-4 py-3 cursor-pointer
						hover:bg-surface-2 focus-visible:bg-surface-2 transition-colors rounded-xl
						list-none min-h-12">
					<span class="flex flex-col gap-0.5 min-w-0">
						<span data-i18n="login.epg.advancedToggle" class="text-sm font-medium text-fg">
							Custom EPG sources (optional)
						</span>
						<span
							data-i18n="login.epg.advancedHelper"
							class="text-xs text-fg-3 leading-relaxed">
							Override the provider's XMLTV guide, or stack extra sources to fill missing channels.
						</span>
					</span>
					<IconChevronDown
						aria-hidden="true"
						stroke={2}
						class="size-4 shrink-0 text-fg-3 transition-[transform,color] duration-200
							group-open:rotate-180 group-open:text-accent"
					/>
				</summary>

				<div class="flex flex-col gap-5 px-4 pb-4 pt-1">
					<!-- Primary override -->
					<label class="flex flex-col gap-2">
						<span
							data-i18n="login.epg.primaryLabel"
							class="text-eyebrow font-medium uppercase text-fg-3">
							Primary EPG URL
						</span>
						<input
							id="epgPrimary"
							type="url"
							placeholder="Leave empty to use the provider's default"
							data-i18n-attr="placeholder:login.epg.primaryPlaceholder"
							autocapitalize="off"
							spellcheck="false"
							inputmode="url"
							class="field-input"
						/>
						<span
							id="epgPrimaryStatus"
							class="hidden text-xs leading-relaxed"></span>
						<span data-i18n="login.epg.primaryHelper" class="text-xs text-fg-3 leading-relaxed">
							XMLTV URL. Plain XML or gzipped (.xml.gz). Overrides the auto-detected source.
						</span>
					</label>

					<!-- Additional sources -->
					<div class="flex flex-col gap-2">
						<span
							data-i18n="login.epg.additionalLabel"
							class="text-eyebrow font-medium uppercase text-fg-3">
							Additional sources
						</span>
						<span data-i18n="login.epg.additionalHelper" class="text-xs text-fg-3 leading-relaxed">
							Stacked in order. Each one fills channels the previous sources didn't supply - they never override the primary.
						</span>
						<ul id="epgAdditionalList" class="flex flex-col gap-2"></ul>
					</div>

					<div class="flex flex-col gap-2">
						<div class="flex flex-wrap items-center gap-2">
							<button
								id="epgAddBtn"
								type="button"
								class="inline-flex items-center gap-1.5 rounded-lg border border-line bg-bg px-3 py-1.5 text-sm text-fg-2
									hover:bg-surface-2 hover:text-fg focus-visible:bg-surface-2 focus-visible:border-accent transition-colors">
								<IconPlus aria-hidden="true" stroke={2} class="size-3.5" />
								<span data-i18n="login.epg.addSource">Add another source</span>
							</button>
							<button
								id="epgTestBtn"
								type="button"
								data-i18n="login.epg.testButton"
								class="inline-flex items-center gap-1.5 rounded-lg border border-line bg-bg px-3 py-1.5 text-sm text-fg-2
									hover:bg-surface-2 hover:text-fg focus-visible:bg-surface-2 focus-visible:border-accent transition-colors
									disabled:opacity-50 disabled:cursor-not-allowed">
								Test sources
							</button>
						</div>
						<div
							id="epgTestStatus"
							class="hidden items-start gap-2.5 rounded-xl border px-3.5 py-2.5 text-sm leading-relaxed"></div>
					</div>

					<!-- Skip provider auto-default (Xtream only).
					     Same shell pattern as the "Sync with Live TV" row in
					     CategoryPickerDialog so cross-page checkbox rows feel
					     like one component. The :has(:checked) selector
					     tinges the row accent when active so the user can
					     see at a glance that the toggle is on, without
					     squinting at the checkbox tick. -->
					<label
						id="epgDisableProviderRow"
						class="flex items-start gap-2.5 rounded-lg border border-line bg-surface-2 px-3 py-2 text-sm text-fg-2 shrink-0
							cursor-pointer hover:bg-surface-3 focus-within:border-accent transition-colors
							has-[:checked]:border-accent has-[:checked]:bg-accent-soft/40">
						<input
							id="epgDisableProvider"
							type="checkbox"
							class="mt-0.5 size-4 accent-accent shrink-0"
						/>
						<span class="flex flex-col leading-tight min-w-0">
							<span
								data-i18n="login.epg.disableProviderLabel"
								class="text-fg">
								Don't use the provider's default EPG
							</span>
							<span
								data-i18n="login.epg.disableProviderHelper"
								class="text-xs text-fg-3">
								Skip the auto-detected source. Only the URLs above will be used - lets you verify a custom EPG works on its own.
							</span>
						</span>
					</label>
				</div>
			</details>

			<!-- Status -->
			<div
				id="status"
				class="hidden items-start gap-2.5 rounded-xl border px-3.5 py-2.5 text-sm leading-relaxed">
			</div>

			<!-- "Run full diagnostic" affordance + result panel. Hidden until the
			     user has hit Test once; clicking the link runs the multi-step
			     wizard in lib/diagnostic.ts and renders the step-by-step result. -->
			<div id="diagnostic-affordance" class="hidden flex-col gap-2">
				<button
					id="diagnostic-run-btn"
					type="button"
					class="self-start inline-flex items-center gap-1.5 rounded-lg border border-line bg-bg px-3.5 py-2 min-h-10 text-xs text-fg-2
						hover:bg-surface-2 hover:text-fg focus-visible:bg-surface-2 focus-visible:border-accent transition-colors">
					<span data-i18n="diagnostic.runFull">Run full diagnostic</span>
				</button>
				<div
					id="diagnostic-result"
					class="hidden"
					role="status"
					aria-live="polite"
					aria-atomic="false"></div>
			</div>

			<!-- Actions -->
			<div
				class="flex flex-wrap gap-2 pt-2 mt-2 border-t border-line">
				<button
					id="testBtn"
					type="button"
					data-i18n="login.action.test"
					class="btn">
					Test connection
				</button>
				<button
					id="saveBtn"
					type="submit"
					data-i18n="login.action.save"
					class="btn-primary ml-auto">
					Save and continue
				</button>
			</div>
		</form>

		<p data-i18n="login.fineprint" class="mt-12 text-xs text-fg-3 leading-relaxed">
			This app does not provide any content. Use any
			Xtream-compatible IPTV subscription, or paste any M3U/M3U8 playlist
			URL. Public test playlists are available at iptv-org.github.io/iptv.
		</p>

		</div>
	</main>
</Layout>

<script>
	import {
		addEntry,
		updateEntry,
		getEntries,
		parseXtreamUrl,
		resolveServerScheme,
		resolveM3UScheme,
		LOCAL_M3U_SCHEME,
		readLocalM3UContent,
		isTauri,
	} from "@/scripts/lib/creds.js";
	import { t, LOCALE_EVENT } from "@/scripts/lib/i18n.js";
	import { parseM3U } from "@/scripts/lib/m3u-parser.ts";
	import { isAndroidFsActive, pickM3UFile } from "@/scripts/lib/android-fs.js";
	import { log } from "@/scripts/lib/log.js";
	import {
		invalidateEpgPlaylist,
		EPG_SOURCE_STATUS_EVENT,
		testEpgSource,
	} from "@/scripts/lib/epg-data.js";
	import { ICON_X } from "@/scripts/lib/icons.ts";

	const EPG_URL_RX = /^https?:\/\/[^\s]+$/i;

	const MAX_LOCAL_M3U_BYTES = 25 * 1024 * 1024; // 25 MiB

	const $ = (id) => /** @type {any} */ (document.getElementById(id));

	const tabXtream = $("tab-xtream");
	const tabM3u = $("tab-m3u");
	const tabLocal = $("tab-local");
	const xFields = $("xtream-fields");
	const mFields = $("m3u-fields");
	const lFields = $("local-fields");
	const titleEl = $("title");
	const serverEl = $("serverUrl");
	const userEl = $("username");
	const passEl = $("password");
	const m3uEl = $("m3uUrl");
	const localPickBtn = $("localPickBtn");
	const localFileInput = $("localFileInput");
	const localFileNameEl = $("localFileName");
	const statusEl = $("status");
	const diagnosticAffordance = $("diagnostic-affordance");
	const diagnosticRunBtn = $("diagnostic-run-btn");
	const diagnosticResultEl = $("diagnostic-result");
	const testBtn = $("testBtn");
	const saveBtn = $("saveBtn");
	const pageTitle = $("page-title");
	const pageSubtitle = $("page-subtitle");

	const epgDetails = $("epg-sources");
	const epgPrimaryEl = /** @type {HTMLInputElement} */ ($("epgPrimary"));
	const epgPrimaryStatus = $("epgPrimaryStatus");
	const epgListEl = $("epgAdditionalList");
	const epgAddBtn = $("epgAddBtn");

	const mirrorsDetails = $("mirrors-section");
	const mirrorsListEl = $("mirrorsList");
	const mirrorsAddBtn = $("mirrorsAddBtn");
	const xtreamAdvancedDetails = $("xtream-advanced");
	const liveContainerEl = /** @type {HTMLSelectElement} */ ($("liveContainer"));
	const epgTestBtn = $("epgTestBtn");
	const epgTestStatus = $("epgTestStatus");
	const epgDisableProviderRow = $("epgDisableProviderRow");
	const epgDisableProviderEl = /** @type {HTMLInputElement} */ ($("epgDisableProvider"));
	let epgTestAbort = null;

	/** @type {{ name: string, text: string } | null} */
	let pickedLocal = null;

	function readEpgUrlsFromForm() {
		const primary = (epgPrimaryEl?.value || "").trim();
		const additional = [];
		const inputs = epgListEl?.querySelectorAll("input[data-role='epg-additional']") || [];
		for (const input of inputs) {
			const value = (/** @type {HTMLInputElement} */ (input).value || "").trim();
			if (value) additional.push(value);
		}
		return { primary, additional };
	}

	function setEpgError(el, key) {
		if (!el) return;
		el.classList.remove("text-bad", "text-good", "text-warn");
		if (!key) {
			el.classList.add("hidden");
			el.textContent = "";
			el.removeAttribute("data-i18n");
			return;
		}
		el.classList.remove("hidden");
		el.classList.add("text-bad");
		el.setAttribute("data-i18n", key);
		el.textContent = t(key);
	}

	function validateEpgUrlInputs() {
		setEpgError(epgPrimaryStatus, null);
		const primary = (epgPrimaryEl?.value || "").trim();
		if (primary && !EPG_URL_RX.test(primary)) {
			setEpgError(epgPrimaryStatus, "login.epg.invalidUrl");
			return false;
		}
		const seen = new Set();
		if (primary) seen.add(primary);
		let ok = true;
		const rows = epgListEl?.querySelectorAll("[data-role='epg-row']") || [];
		for (const row of rows) {
			const input = /** @type {HTMLInputElement} */ (row.querySelector("input"));
			const statusSpan = row.querySelector("[data-role='epg-row-status']");
			if (!input || !statusSpan) continue;
			statusSpan.classList.add("hidden");
			statusSpan.classList.remove("text-bad", "text-good", "text-warn");
			statusSpan.removeAttribute("data-i18n");
			statusSpan.textContent = "";
			const value = input.value.trim();
			if (!value) continue;
			if (!EPG_URL_RX.test(value)) {
				statusSpan.classList.remove("hidden");
				statusSpan.classList.add("text-bad");
				statusSpan.setAttribute("data-i18n", "login.epg.invalidUrl");
				statusSpan.textContent = t("login.epg.invalidUrl");
				ok = false;
				continue;
			}
			if (seen.has(value)) {
				statusSpan.classList.remove("hidden");
				statusSpan.classList.add("text-warn");
				statusSpan.setAttribute("data-i18n", "login.epg.duplicateUrl");
				statusSpan.textContent = t("login.epg.duplicateUrl");
				ok = false;
				continue;
			}
			seen.add(value);
		}
		return ok;
	}

	function makeRemoveBtn(row) {
		const btn = document.createElement("button");
