	// Same palette + dot pattern as the connection-test status above so
	// "Test sources" and "Test connection" read as one component family.
	const EPG_TEST_PALETTE = {
		good: "border-ok/30 bg-ok/10 text-ok",
		warn: "border-warn/30 bg-warn/10 text-warn",
		bad: "border-bad/30 bg-bad/10 text-bad",
		busy: "border-line bg-surface text-fg-2",
	};

	function setEpgTestStatus(message, tone) {
		if (!epgTestStatus) return;
		epgTestStatus.removeAttribute("data-celebrate");
		if (!message) {
			epgTestStatus.classList.add("hidden");
			epgTestStatus.classList.remove("flex");
			epgTestStatus.innerHTML = "";
			return;
		}
		epgTestStatus.classList.remove("hidden");
		epgTestStatus.classList.add("flex");
		const palette = EPG_TEST_PALETTE[tone] || EPG_TEST_PALETTE.busy;
		epgTestStatus.className =
			"flex items-start gap-2.5 rounded-xl border px-3.5 py-2.5 text-sm leading-relaxed " +
			palette;
		const dot = `<span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 rounded-full bg-current shrink-0"></span>`;
		epgTestStatus.innerHTML = `${dot}<span>${escapeText(message)}</span>`;
	}

	async function runEpgTest() {
		if (!validateEpgUrlInputs()) {
			setEpgTestStatus(t("login.epg.invalidUrl"), "bad");
			return;
		}
		const { primary, additional } = readEpgUrlsFromForm();
		const targets = [];
		if (primary) {
			targets.push({ url: primary, badge: epgPrimaryStatus });
		}
		const rows = Array.from(
			epgListEl?.querySelectorAll("[data-role='epg-row']") || []
		);
		for (const row of rows) {
			const input = /** @type {HTMLInputElement} */ (row.querySelector("input"));
			const badge = row.querySelector("[data-role='epg-row-status']");
			const value = (input?.value || "").trim();
			if (!value) continue;
			if (additional.includes(value)) {
				targets.push({ url: value, badge });
			}
		}
		if (!targets.length) {
			setEpgTestStatus(t("login.epg.testNoSources"), "warn");
			return;
		}

		// Cancel anything in-flight from a previous click.
		if (epgTestAbort) {
			try { epgTestAbort.abort(); } catch {}
		}
		epgTestAbort = new AbortController();
		const signal = epgTestAbort.signal;

		if (epgTestBtn) {
			epgTestBtn.disabled = true;
			epgTestBtn.removeAttribute("data-i18n");
			epgTestBtn.textContent = t("login.epg.testButtonBusy");
		}
		setEpgTestStatus(
			t("login.epg.testing", { count: targets.length.toLocaleString() }),
			"busy"
		);

		// Mark each badge as in-flight before any awaits.
		for (const target of targets) {
			if (!target.badge) continue;
			target.badge.classList.remove("hidden", "text-bad", "text-good", "text-warn");
			target.badge.classList.add("text-fg-3");
			target.badge.removeAttribute("data-i18n");
			target.badge.textContent = t("login.epg.sourceFetching");
		}

		const results = await Promise.all(
			targets.map((target) =>
				testEpgSource(target.url, { signal }).then((res) => ({ target, res }))
			)
		);

		if (signal.aborted) return;

		let okCount = 0;
		let errCount = 0;
		for (const { target, res } of results) {
			if (!target.badge) continue;
			target.badge.classList.remove("text-fg-3", "text-bad", "text-good", "text-warn");
			target.badge.removeAttribute("data-i18n");
			if (res.ok) {
				okCount++;
				target.badge.classList.remove("hidden");
				target.badge.classList.add("text-good");
				target.badge.textContent = t("login.epg.sourceStatusOk", {
					count: (res.count || 0).toLocaleString(),
				});
			} else {
				errCount++;
				target.badge.classList.remove("hidden");
				target.badge.classList.add("text-bad");
				target.badge.textContent = t("login.epg.sourceStatusError", {
					error: res.error || "Unknown error",
				});
			}
		}

		if (epgTestBtn) {
			epgTestBtn.disabled = false;
			epgTestBtn.setAttribute("data-i18n", "login.epg.testButton");
			epgTestBtn.textContent = t("login.epg.testButton");
		}
		setEpgTestStatus(
			t("login.epg.testDone", {
				ok: okCount.toLocaleString(),
				total: targets.length.toLocaleString(),
			}),
			errCount === 0 ? "good" : okCount === 0 ? "bad" : "warn"
		);
		if (errCount === 0 && epgTestStatus) {
			void epgTestStatus.offsetWidth;
			epgTestStatus.setAttribute("data-celebrate", "true");
		}
		epgTestAbort = null;
	}
	epgTestBtn?.addEventListener("click", () => {
		runEpgTest();
	});

	function refreshDisableProviderVisibility() {
		if (!epgDisableProviderRow) return;
		epgDisableProviderRow.style.display = mode === "xtream" ? "" : "none";
	}

	const params = new URLSearchParams(location.search);
	const editingId = params.get("edit");
	const isDemo = params.get("demo") === "1";
	const DEMO_M3U_URL = "https://iptv-org.github.io/iptv/index.m3u";
	let editing = null;
	let mode = "xtream";

	const ACTIVE_TAB =
		"bg-accent-soft text-accent ring-1 ring-accent/30";
	const IDLE_TAB = "text-fg-2 hover:text-fg";

	function setMode(next) {
		const prev = mode;
		mode = next;
		const isX = next === "xtream";
		const isM = next === "m3u";
		const isL = next === "local-m3u";
		xFields.classList.toggle("hidden", !isX);
		xFields.classList.toggle("flex", isX);
		mFields.classList.toggle("hidden", !isM);
		mFields.classList.toggle("flex", isM);
		lFields.classList.toggle("hidden", !isL);
		lFields.classList.toggle("flex", isL);

		if (prev && prev !== next) {
			const shown = isX ? xFields : isM ? mFields : lFields;
			shown.classList.remove("fade-section");
			void shown.offsetWidth;
			shown.classList.add("fade-section");
		}

		refreshDisableProviderVisibility();

		applyTabStyles(tabXtream, isX);
		applyTabStyles(tabM3u, isM);
		applyTabStyles(tabLocal, isL);

		// Local-file picking is its own verification - the Test button has no
		// remote endpoint to probe, so hide it. We still run parseM3U inline
		// after picking and surface the result via showStatus().
		testBtn.classList.toggle("hidden", isL);
		clearStatus();
		hideDiagnosticResult();
		if (diagnosticAffordance) {
			diagnosticAffordance.classList.add("hidden");
			diagnosticAffordance.classList.remove("flex");
		}
	}

	function applyTabStyles(btn, active) {
