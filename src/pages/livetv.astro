---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/SearchInput.astro";
import CategoryPickerDialog from "@/components/CategoryPickerDialog.astro";
import WelcomeCard from "@/components/WelcomeCard.astro";
import { IconDeviceTv, IconChevronDown, IconCalendarTime, IconLayoutGrid } from "@tabler/icons-svelte";

const devPlaybackBuild = import.meta.env.DEV ? "playback m3u8-audio" : null;
---

<Layout pageTitle="Live TV">
	{devPlaybackBuild ? (
		<div
			id="dev-playback-build"
			class="fixed bottom-3 left-3 z-9999 rounded-md border border-line bg-surface/95 px-2 py-1 text-[10px] font-mono text-fg-3 shadow-lg pointer-events-none"
			aria-hidden="true">
			DEV · {devPlaybackBuild}
		</div>
	) : null}
	<script is:inline>
		try {
			var raw = localStorage.getItem("xt_playlists") || "";
			var hasEntries = false;
			if (raw) {
				var parsed = JSON.parse(raw);
				hasEntries = !!(
					parsed &&
					Array.isArray(parsed.entries) &&
					parsed.entries.length
				);
			}
			if (!hasEntries) {
				document.documentElement.setAttribute("data-first-run", "true");
			}
		} catch (e) {}
	</script>

	<main
		id="livetv-page-main"
		class="w-full max-w-480 mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 md:landscape:pt-6 pb-6
			flex flex-col gap-4 flex-1 min-h-0">

		<section
			id="livetv-welcome"
			aria-labelledby="welcome-heading"
			class="livetv-welcome hidden flex-1 min-h-0 items-center justify-center py-6">
			<WelcomeCard />
		</section>

		<section
			id="livetv-main"
			class="flex flex-col md:landscape:flex-row lg:flex-row gap-4 flex-1 min-h-0">

			<!-- Channels (bottom on mobile, left column on desktop) -->
			<aside
				class="order-2 md:landscape:order-1 lg:order-1
					md:landscape:w-(--xt-channels-w,24rem) lg:w-(--xt-channels-w,28rem)
					md:landscape:shrink-0 lg:shrink-0 md:landscape:min-h-0 lg:min-h-0">
				<div
					class="rounded-2xl border border-line bg-surface p-3 h-full flex flex-col gap-3 md:landscape:min-h-0 lg:min-h-0">

					<div class="flex gap-2 shrink-0">
						<button
							id="category-picker-trigger"
							type="button"
							aria-haspopup="dialog"
							aria-controls="category-picker-dialog"
							class="rounded-xl border border-line bg-bg px-3.5 py-2 min-h-11 text-sm flex items-center gap-2 text-left flex-1 min-w-0
								hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
								transition-colors">
							<span data-i18n="list.category" class="text-fg-3 shrink-0">Category</span>
							<span
								id="category-picker-label"
								data-i18n="list.allCategories"
								class="text-fg truncate flex-1">All categories</span>
							<IconChevronDown
								aria-hidden="true"
								stroke={2}
								class="size-4 text-fg-3 shrink-0"
							/>
						</button>
						<button
							id="epg-toggle"
							type="button"
							aria-pressed="true"
							aria-label="Show EPG for the current channel"
							title="Show EPG"
							data-i18n-attr="aria-label:livetv.epgToggle.aria;title:livetv.epgToggle.title"
							class="rounded-xl border border-line bg-bg px-3.5 py-2 min-h-11 min-w-11 text-sm text-fg-2 inline-flex items-center justify-center gap-2 shrink-0
								hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
								aria-pressed:border-accent aria-pressed:bg-surface-2 aria-pressed:text-fg
								transition-colors">
							<IconCalendarTime
								aria-hidden="true"
								stroke={2}
								class="size-4"
							/>
							<span data-i18n="livetv.epgPanelHeading" class="hidden sm:inline">EPG</span>
						</button>
						<a
							href="/epg"
							aria-label="Open the full EPG schedule grid"
							title="Open schedule grid"
							data-i18n-attr="aria-label:livetv.openSchedule.aria;title:livetv.openSchedule.title"
							class="rounded-xl border border-line bg-bg px-3.5 py-2 min-h-11 min-w-11 text-sm text-fg-2 inline-flex items-center justify-center shrink-0
								hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
								transition-colors">
							<IconLayoutGrid
								aria-hidden="true"
								stroke={2}
								class="size-4"
							/>
							<span data-i18n="livetv.openSchedule.label" class="sr-only">Schedule grid</span>
						</a>
					</div>

					<SearchInput
						id="search"
						label="Search channels"
						placeholder="Search channels…"
						clearButtonId="clear-search"
						labelKey="list.searchChannels"
						placeholderKey="list.searchChannelsPlaceholder"
						clearKey="common.clear"
					/>

					<div
						id="list"
						class="relative flex-1 min-h-0 overflow-auto pr-1 custom-scroll
							max-h-96 md:landscape:max-h-dvh lg:max-h-dvh">
						<div id="spacer"></div>
						<div id="viewport" class="absolute inset-x-0 top-0"></div>
					</div>

					<div
						id="list-status"
						data-i18n="list.noPlaylistSelected"
						class="px-2.5 text-sm text-fg-3 tabular-nums shrink-0">
						No playlist selected.
					</div>
				</div>
			</aside>

			<!-- Player + EPG (top on mobile, right column on desktop/landscape) -->
			<section
				class="order-1 md:landscape:order-2 lg:order-2
					md:landscape:flex-1 lg:flex-1 min-w-0 md:landscape:min-h-0 lg:min-h-0">
				<div
					class="rounded-2xl border border-line bg-surface p-3 h-full flex flex-col gap-3 md:landscape:min-h-0 lg:min-h-0">
					<div
						id="player-wrap"
						class="player-wrap aspect-video w-full mx-auto overflow-hidden rounded-xl bg-black ring-1 ring-line flex items-center justify-center shrink-0 relative">
						<div
							id="player-empty"
							class="absolute inset-0 flex flex-col items-center justify-center gap-6 text-center px-6 pointer-events-none">
							<div class="player-empty-glow" aria-hidden="true"></div>
							<IconDeviceTv
								aria-hidden="true"
								stroke={0.6}
								class="size-24 sm:size-28 lg:size-36 text-fg-3/55 relative z-10"
							/>
							<div class="flex flex-col gap-2.5 relative z-10">
								<span class="inline-flex items-center gap-2 self-center text-eyebrow font-semibold uppercase tracking-[0.22em] text-fg-3">
									<span aria-hidden="true" class="size-1.5 rounded-full bg-accent shadow-[0_0_0_4px_var(--color-accent-soft)]"></span>
									<span data-i18n="livetv.idle">Idle</span>
								</span>
								<p data-i18n="livetv.pickChannel" class="text-fg leading-[0.95] tracking-[-0.03em] font-bold"
									style="font-size: clamp(1.75rem, 3vw + 1rem, 3.5rem);">
									Pick a channel.
								</p>
								<p data-i18n="livetv.pickChannelHelper" class="text-fg-3 text-xs sm:text-sm">
									Choose from the list, or change category.
								</p>
							</div>
						</div>
						<video
							id="player"
							class="video-js vjs-default-skin vjs-big-play-centered h-full w-full"
							controls
							hidden
							playsinline></video>
						<div
							id="radio-display"
							class="radio-display max-[480px]:flex-col max-[480px]:text-center max-[480px]:items-center"
							aria-hidden="true">
							<div
								class="radio-display__art relative shrink-0 aspect-square rounded-2xl bg-surface-2 overflow-hidden"
								data-radio-art>
								<div class="radio-display__art-fallback absolute inset-0 grid place-items-center" aria-hidden="true">
									<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M14 4l-9 1.5v12"/><path d="M16 18a2 2 0 1 0 -4 0a2 2 0 0 0 4 0z"/><path d="M9 17a2 2 0 1 0 -4 0a2 2 0 0 0 4 0z"/><path d="M14 17v-12"/></svg>
								</div>
								<img
									alt=""
									decoding="async"
									referrerpolicy="no-referrer"
									data-radio-cover
									class="absolute inset-0 w-full h-full object-contain p-3 opacity-0 data-[loaded=true]:opacity-100 transition-opacity duration-[240ms]" />
							</div>
							<div class="radio-display__meta flex flex-col gap-2 min-w-0 flex-1 pb-14 max-[480px]:items-center max-[480px]:pb-16">
								<span
									class="radio-display__eyebrow inline-flex items-center gap-2 text-fg-3 text-[0.625rem] font-semibold uppercase tracking-[0.22em]"
									data-i18n="livetv.radioEyebrow"
								>On air · Radio</span>
								<p
									class="radio-display__name text-fg font-bold tracking-tight leading-tight min-w-0 line-clamp-2 text-[clamp(1.5rem,3vw,2.25rem)]"
									data-radio-name>-</p>
								<p
									class="radio-display__nowplaying text-fg-2 text-sm m-0 min-w-0 line-clamp-2"
									data-radio-nowplaying
									hidden></p>
							</div>
						</div>
					</div>

					<div
						id="current"
						class="flex items-center justify-between gap-2 px-1 text-sm text-fg-2 shrink-0">
						<div class="flex items-center gap-2 min-w-0">
							<span data-i18n="livetv.statusOff" class="status-badge status-badge--off shrink-0">OFF</span>
							<span class="truncate">-</span>
						</div>
					</div>

					<div
						id="epg"
						class="border-t border-line overflow-auto custom-scroll md:landscape:flex-1 md:landscape:min-h-0 lg:flex-1 lg:min-h-0">
						<div data-i18n="livetv.epgPanelHeading" class="text-sm font-medium text-fg sticky top-0 bg-surface pt-3 pb-2 z-10">EPG</div>
						<div id="epg-list" class="space-y-2 text-sm pb-3"></div>
					</div>
				</div>
			</section>
		</section>

		<!-- Categories popover -->
		<CategoryPickerDialog idPrefix="category-picker" />

		<div
			id="app-version"
			class="fixed bottom-[max(0.5rem,env(safe-area-inset-bottom))] right-[max(0.75rem,env(safe-area-inset-right))] text-2xs text-fg-3 opacity-70 tabular-nums pointer-events-none">
			Loading…
		</div>
	</main>

	<style>
		html[data-first-run="true"] #livetv-main { display: none; }
		html[data-first-run="true"] #livetv-welcome { display: flex; }
		html[data-first-run="true"] #livetv-page-main { min-height: auto; }

		.player-wrap {
			max-height: 60dvh;
			max-width: calc(60dvh * 16 / 9);
		}

		/* Radio mode */
		.radio-display { display: none; }
		.player-wrap[data-radio-mode="on"] {
			aspect-ratio: auto;
			max-height: none;
			max-width: 100%;
			height: auto;
			min-height: clamp(14rem, 28dvh, 22rem);
			background:
				radial-gradient(
					120% 80% at 50% 0%,
					color-mix(in oklch, var(--color-accent) 24%, transparent) 0%,
					transparent 60%
				),
				linear-gradient(180deg, var(--color-surface-2), var(--color-surface));
			padding: clamp(1rem, 3vw, 2rem);
			gap: clamp(1rem, 3vw, 2rem);
			justify-content: flex-start;
		}
		.player-wrap[data-radio-mode="on"] #player-empty { display: none !important; }
		.player-wrap[data-radio-mode="on"] .radio-display {
			display: flex;
			align-items: center;
			gap: clamp(1rem, 3vw, 2rem);
			width: 100%;
			min-width: 0;
		}
		.player-wrap[data-radio-mode="on"] .video-js,
		.player-wrap[data-radio-mode="on"] #player {
			position: absolute;
			inset: auto 0 0 0;
			width: 100%;
			height: 3.25rem;
			padding-top: 0 !important;
			background: transparent !important;
		}
		.player-wrap[data-radio-mode="on"] .video-js .vjs-tech,
		.player-wrap[data-radio-mode="on"] #player video,
		.player-wrap[data-radio-mode="on"] .video-js .vjs-poster {
			display: none;
		}
		.player-wrap[data-radio-mode="on"] .video-js .vjs-control-bar {
			background: color-mix(in oklch, var(--color-bg) 70%, transparent);
			border-top: 1px solid var(--color-line);
			border-radius: 0 0 0.75rem 0.75rem;
		}

		.radio-display__art {
			width: clamp(7rem, 16vw, 11rem);
			box-shadow:
				0 0 0 1px var(--color-line),
				0 20px 40px -12px color-mix(in oklch, var(--color-accent) 38%, transparent),
				0 8px 20px -6px rgb(0 0 0 / 0.55);
		}
		.radio-display__art-fallback {
			color: color-mix(in oklch, var(--color-fg-3) 80%, transparent);
		}
		.radio-display__eyebrow::before {
			content: "";
			width: 0.375rem;
			height: 0.375rem;
			border-radius: 999px;
			background: var(--color-accent);
			box-shadow: 0 0 0 4px var(--color-accent-soft);
		}

		@media (max-width: 480px) {
			.player-wrap[data-radio-mode="on"] {
				flex-direction: column;
				padding: 1rem;
			}
		}
	</style>

	<script>
		import "../scripts/stream/stream.ts";
		import "../scripts/updater-startup.js";
		import { injectVersion } from "../scripts/version.js";
		injectVersion();

		const playerEl = document.getElementById("player");
		const playerEmpty = document.getElementById("player-empty");
		if (playerEl && playerEmpty) {
			const sync = () => {
				playerEmpty.style.display = playerEl.hasAttribute("hidden") ? "" : "none";
			};
			sync();
			new MutationObserver(sync).observe(playerEl, {
				attributes: true,
				attributeFilter: ["hidden"],
			});
		}

		const epgToggle = /** @type {HTMLButtonElement|null} */ (
			document.getElementById("epg-toggle")
		);
		const epgPanel = document.getElementById("epg");
		if (epgToggle && epgPanel) {
			const KEY_VISIBLE = "xt_epg_visible";
			const KEY_DEFAULT = "xt_epg_open_default";

			const readDefault = () => {
				try {
					const v = localStorage.getItem(KEY_DEFAULT);
					return v === null ? true : v === "true";
				} catch {
					return true;
				}
			};
			const readVisible = () => {
				try {
					const v = localStorage.getItem(KEY_VISIBLE);
					return v === null ? readDefault() : v === "true";
				} catch {
					return true;
				}
			};

			const apply = (visible) => {
				epgPanel.classList.toggle("hidden", !visible);
				epgToggle.setAttribute("aria-pressed", String(visible));
			};

			apply(readVisible());

			epgToggle.addEventListener("click", () => {
				const next = epgToggle.getAttribute("aria-pressed") !== "true";
				try {
					localStorage.setItem(KEY_VISIBLE, String(next));
				} catch {}
				apply(next);
			});
		}
	</script>
</Layout>
